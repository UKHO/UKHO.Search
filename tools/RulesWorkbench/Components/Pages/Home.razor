@page "/"

@rendermode InteractiveServer

@using RulesWorkbench.Services
@inject AppConfigRulesSnapshotStore RulesSnapshotStore

<PageTitle>Home</PageTitle>

<h1>Rule Workbench</h1>

@if (_loadError is not null)
{
    <p><strong>Rules failed to load.</strong></p>
    <p>@_loadError</p>
}
else if (_rulesLoaded is null)
{
    <p>Loading rules…</p>
}
else
{
    <p><strong>Provider:</strong> file-share</p>
    <p><strong>Rules loaded:</strong> @_rulesLoaded</p>
}

@code
{
    private int? _rulesLoaded;

    private string? _loadError;

    protected override void OnInitialized()
    {
        try
        {
            _rulesLoaded = RulesSnapshotStore.GetRules(null)
                .Count(x => string.Equals(x.Provider, "file-share", StringComparison.OrdinalIgnoreCase));
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }
}
