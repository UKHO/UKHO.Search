@using Microsoft.JSInterop

@inject IJSRuntime JsRuntime

<div class="json-editor-host" id="@_hostId" style="@HostStyle" @ref="_host"></div>

@implements IAsyncDisposable

@code
{
	private ElementReference _host;
	private IJSObjectReference? _module;
	private IJSObjectReference? _editor;
	private DotNetObjectReference<JsonEditor>? _dotNetRef;
	private readonly string _hostId = $"json-editor-{Guid.NewGuid():N}";

	[Parameter]
	public string Value { get; set; } = string.Empty;

	[Parameter]
	public EventCallback<string> ValueChanged { get; set; }

	[Parameter]
	public bool IsReadOnly { get; set; }

	[Parameter]
 public string HostStyle { get; set; } = "width: 100%; min-height: 70vh; border: 1px solid #dee2e6; border-radius: 0.25rem;";

	[Parameter]
	public bool EnableFolding { get; set; } = true;

	private string? _lastAppliedValue;

  protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			_module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/monacoEditorInterop.js");
            _dotNetRef = DotNetObjectReference.Create(this);
			_editor = await _module.InvokeAsync<IJSObjectReference>(
				"createJsonEditor",
				_host,
				Value,
				IsReadOnly,
				EnableFolding,
                _dotNetRef);
			_lastAppliedValue = Value;
		}
     else if (_editor is not null && _lastAppliedValue != Value)
		{
         await _module!.InvokeVoidAsync("setValue", _editor, Value);
			_lastAppliedValue = Value;
		}

		// Navigating away/back can leave Monaco in a bad visual state even if the component is re-rendered.
		// Force a layout after each render once initialized.
		if (_module is not null && _editor is not null)
		{
           try
			{
				await _module.InvokeVoidAsync("layout", _editor);
			}
			catch (JSDisconnectedException)
			{
				// Ignore: navigation/circuit teardown.
			}
		}
	}

	[JSInvokable]
	public async Task OnEditorValueChanged(string value)
	{
		_lastAppliedValue = value;
		await ValueChanged.InvokeAsync(value);
	}

   public async ValueTask DisposeAsync()
	{
		if (_module is not null)
		{
			try
			{
				if (_editor is not null)
				{
                  try
					{
						await _module.InvokeVoidAsync("dispose", _editor);
					}
					catch (JSDisconnectedException)
					{
						// Ignore: circuit is tearing down.
					}
				}
			}
			finally
			{
               try
				{
					await _module.DisposeAsync();
				}
				catch (JSDisconnectedException)
				{
					// Ignore: circuit is tearing down.
				}
			}
		}

		_dotNetRef?.Dispose();
		_dotNetRef = null;
	}
}
