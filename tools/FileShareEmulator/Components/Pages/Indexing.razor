@page "/indexing"
@rendermode InteractiveServer
@attribute [System.Diagnostics.CodeAnalysis.SuppressMessage("Style", "IDE1006:Naming Styles", Justification = "Type name used for ILogger category")]
@using Elastic.Clients.Elasticsearch
@using FileShareEmulator.Services
@using Microsoft.Extensions.Logging
@inject BusinessUnitLookupService BusinessUnitLookupService
@inject StatisticsService StatisticsService
@inject IndexService IndexService
@inject IngestionQueueService IngestionQueueService
@inject ElasticsearchClient ElasticsearchClient
@inject ILogger<Indexing> Logger

<PageTitle>Indexing</PageTitle>

<RadzenCard Style="max-width: 900px;">
    <h1 style="margin: 0;">Indexing</h1>

    @if (_status is null)
    {
        <RadzenText TextStyle="TextStyle.Body1" Style="margin-top: 1rem;">Loading...</RadzenText>
    }
    else
    {
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" Style="margin-top: 1rem;">
            <RadzenText TextStyle="TextStyle.Body1">Total Batches: @_status.TotalBatches.ToString("N0")</RadzenText>
            <RadzenText TextStyle="TextStyle.Body1">Indexed @_status.IndexedBatches.ToString("N0") Batches Of @_status.TotalBatches.ToString("N0")</RadzenText>
        </RadzenStack>
    }

    <RadzenStack Orientation="Orientation.Vertical" Gap="1.25rem" Style="margin-top: 1.5rem;">
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H6">Index next pending batches</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">Indexes the next <b>Count</b> pending batch(es) only. Use this for incremental indexing.</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem" Style="flex-wrap: wrap;">
                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                    <RadzenLabel Text="Count" Component="indexCount"/>
                    <RadzenNumeric id="indexCount" TValue="int" Style="width: 8rem" Min="1" Value="@(_count ?? 0)" Change="@(args => SetCount(args))"/>
                </RadzenStack>

                <RadzenButton Text="Index" ButtonStyle="ButtonStyle.Secondary" Disabled="@(!_canIndex || _isIndexing || _isDeletingIndexes)" Click="@IndexNextAsync"/>
            </RadzenStack>
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H6">Index all pending batches</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">Indexes everything currently marked as pending, continuing until there are no pending batches left.</RadzenText>
            <RadzenButton Text="Index All" ButtonStyle="ButtonStyle.Primary" Disabled="@(_isIndexing || _isDeletingIndexes || _isClearingQueue)" Click="@IndexAllAsync"/>
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H6">Index batch by id</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">Use this for debugging/testing. Enter a batch id to submit that batch to the ingestion queue.</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem" Style="flex-wrap: wrap;">
                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                    <RadzenLabel Text="Batch id" Component="indexBatchId" />
                    <RadzenTextBox id="indexBatchId" Style="width: 24rem" Value="@_batchIdToIndex" Change="@OnBatchIdChanged" @oninput="@OnBatchIdInput" />
                </RadzenStack>

                <RadzenButton Text="Index batch" ButtonStyle="ButtonStyle.Secondary" Disabled="@(!CanIndexSpecificBatch || _isIndexing || _isDeletingIndexes || _isClearingQueue || _isIndexingSpecificBatch)" Click="@IndexSpecificBatchAsync" />
            </RadzenStack>

            @if (_indexSpecificBatchMessage is not null)
            {
                <RadzenText TextStyle="TextStyle.Body1" Style="@IndexSpecificBatchMessageStyle">@_indexSpecificBatchMessage</RadzenText>
            }
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H6">Index batch by business unit</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">Select a business unit to submit all currently unindexed batches for that business unit to the ingestion queue.</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem" Style="flex-wrap: wrap;">
                <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" Style="min-width: 24rem;">
                    <RadzenLabel Text="Business unit" Component="indexBusinessUnit" />
                    <RadzenDropDown id="indexBusinessUnit"
                                    TValue="int?"
                                    Style="width: 24rem"
                                    Data="@_businessUnits"
                                    TextProperty="DisplayName"
                                    ValueProperty="Id"
                                    Placeholder="Select a business unit"
                                    Value="@_selectedBusinessUnitId"
                                    Change="@OnBusinessUnitChanged"
                                    Disabled="@(_isLoadingBusinessUnits || _isIndexing || _isDeletingIndexes || _isClearingQueue || _isIndexingSpecificBatch || _isIndexingBusinessUnit)" />
                </RadzenStack>

                <RadzenButton Text="@IndexBusinessUnitButtonText"
                              ButtonStyle="ButtonStyle.Secondary"
                              Disabled="@(!CanIndexBusinessUnit || _isLoadingBusinessUnits || _isIndexing || _isDeletingIndexes || _isClearingQueue || _isIndexingSpecificBatch || _isIndexingBusinessUnit)"
                              Click="@IndexBusinessUnitAsync" />
            </RadzenStack>

            @if (_isLoadingBusinessUnits)
            {
                <RadzenText TextStyle="TextStyle.Body2" Style="margin-top: 0.5rem;">Loading business units...</RadzenText>
            }

            @if (_businessUnitLoadErrorMessage is not null)
            {
                <RadzenText TextStyle="TextStyle.Body1" Style="@BusinessUnitLoadMessageStyle">@_businessUnitLoadErrorMessage</RadzenText>
            }

            @if (_indexBusinessUnitMessage is not null)
            {
                <RadzenText TextStyle="TextStyle.Body1" Style="@IndexBusinessUnitMessageStyle">@_indexBusinessUnitMessage</RadzenText>
            }

            @if (_indexBusinessUnitProgressMessage is not null)
            {
                <RadzenText TextStyle="TextStyle.Body2" Style="margin-top: 0.5rem;">@_indexBusinessUnitProgressMessage</RadzenText>
            }
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H6">Reset all batches to pending</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">Marks all batches as pending so they can be re-indexed from scratch (does not delete Elasticsearch indexes).</RadzenText>
            <RadzenButton Text="Reset All" ButtonStyle="ButtonStyle.Light" Disabled="@(_isIndexing || _isDeletingIndexes || _isClearingQueue)" Click="@ResetAllAsync"/>
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H6">Clear ingestion queue</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">Clears <b>all</b> items from the ingestion queue and verifies it is empty before reporting success.</RadzenText>
            <RadzenButton Text="Clear Queue" ButtonStyle="ButtonStyle.Danger" Disabled="@(_isIndexing || _isDeletingIndexes || _isClearingQueue)" Click="@ClearQueueAsync" />

            @if (_clearQueueMessage is not null)
            {
                <RadzenText TextStyle="TextStyle.Body1" Style="@ClearQueueMessageStyle">@_clearQueueMessage</RadzenText>
            }

            @if (_isClearingQueue && !string.IsNullOrWhiteSpace(_clearQueueStage))
            {
                <RadzenText TextStyle="TextStyle.Body2" Style="margin-top: 0.5rem;">@_clearQueueStage</RadzenText>
            }
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H6">Delete Elasticsearch indexes</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">Deletes <b>all</b> indexes in the connected Elasticsearch instance (using <code>*</code>). Use with caution.</RadzenText>
            <RadzenButton Text="Delete Indexes" ButtonStyle="ButtonStyle.Danger" Disabled="@(_isIndexing || _isDeletingIndexes || _isClearingQueue)" Click="@DeleteIndexesAsync"/>

            @if (_isDeletingIndexes && !string.IsNullOrWhiteSpace(_deleteIndexesStage))
            {
                <RadzenText TextStyle="TextStyle.Body2" Style="margin-top: 0.5rem;">@_deleteIndexesStage</RadzenText>
            }

            @if (_deleteIndexesMessage is not null)
            {
                <RadzenText TextStyle="TextStyle.Body1" Style="@DeleteIndexesMessageStyle">@_deleteIndexesMessage</RadzenText>
            }
        </RadzenStack>
    </RadzenStack>
</RadzenCard>

@code
{
    private StatisticsService.IndexingStatus? _status;
    private PeriodicTimer? _timer;
    private readonly CancellationTokenSource _disposeCts = new();

    private int? _count = 1;
    private bool _canIndex;
    private bool _isIndexing;

    private string? _batchIdToIndex;
    private bool _isIndexingSpecificBatch;
    private bool _indexSpecificBatchFailed;
    private string? _indexSpecificBatchMessage;

    private IReadOnlyList<BusinessUnitOptionDto> _businessUnits = Array.Empty<BusinessUnitOptionDto>();
    private int? _selectedBusinessUnitId;
    private bool _isLoadingBusinessUnits;
    private string? _businessUnitLoadErrorMessage;
    private bool _isIndexingBusinessUnit;
    private bool _indexBusinessUnitFailed;
    private string? _indexBusinessUnitMessage;
    private string? _indexBusinessUnitProgressMessage;

    private bool _isDeletingIndexes;
    private bool _deleteIndexesFailed;
    private string? _deleteIndexesMessage;
    private string? _deleteIndexesStage;

    private bool _isClearingQueue;
    private bool _clearQueueFailed;
    private string? _clearQueueMessage;
    private string? _clearQueueStage;

    private string ClearQueueMessageStyle => "margin-top: 0.75rem; white-space: pre-wrap; color: " + (_clearQueueFailed ? "var(--rz-danger)" : "var(--rz-success)");

    private string DeleteIndexesMessageStyle => "margin-top: 0.75rem; white-space: pre-wrap; color: " + (_deleteIndexesFailed ? "var(--rz-danger)" : "var(--rz-success)");

    private bool CanIndexSpecificBatch => !string.IsNullOrWhiteSpace(_batchIdToIndex);
    private string IndexSpecificBatchMessageStyle => "margin-top: 0.75rem; white-space: pre-wrap; color: " + (_indexSpecificBatchFailed ? "var(--rz-danger)" : "var(--rz-success)");
    private bool CanIndexBusinessUnit => _selectedBusinessUnitId is > 0 && _businessUnitLoadErrorMessage is null;
    private string BusinessUnitLoadMessageStyle => "margin-top: 0.75rem; white-space: pre-wrap; color: var(--rz-danger)";
    private string IndexBusinessUnitMessageStyle => "margin-top: 0.75rem; white-space: pre-wrap; color: " + (_indexBusinessUnitFailed ? "var(--rz-danger)" : "var(--rz-success)");
    private string IndexBusinessUnitButtonText => _isIndexingBusinessUnit ? "Indexing Business Unit..." : "Index Business Unit";

    private async Task OnBatchIdChanged(object? value)
    {
        _batchIdToIndex = value?.ToString();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnBatchIdInput(ChangeEventArgs e)
    {
        _batchIdToIndex = e.Value?.ToString();
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnInitializedAsync()
    {
        ValidateCount();
        _status = await StatisticsService.GetIndexingStatusAsync()
                                         .ConfigureAwait(false);
        await LoadBusinessUnitsAsync().ConfigureAwait(false);

        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = PollAsync();
    }

    private async Task LoadBusinessUnitsAsync()
    {
        _isLoadingBusinessUnits = true;
        _businessUnitLoadErrorMessage = null;

        try
        {
            var result = await BusinessUnitLookupService.GetBusinessUnitsAsync(_disposeCts.Token)
                                                        .ConfigureAwait(false);

            if (!result.IsSuccess)
            {
                _businessUnits = Array.Empty<BusinessUnitOptionDto>();
                _businessUnitLoadErrorMessage = result.ErrorMessage ?? "Failed to load business units.";
                return;
            }

            _businessUnits = result.BusinessUnits;
        }
        finally
        {
            _isLoadingBusinessUnits = false;
        }
    }

    private async Task PollAsync()
    {
        if (_timer is null) return;

        try
        {
            while (await _timer.WaitForNextTickAsync()
                               .ConfigureAwait(false))
            {
                _status = await StatisticsService.GetIndexingStatusAsync()
                                                 .ConfigureAwait(false);
                await InvokeAsync(StateHasChanged);
            }
        }

        catch (OperationCanceledException)
        {
        }
    }

    private async Task IndexSpecificBatchAsync()
    {
        if (_isIndexing || _isDeletingIndexes || _isClearingQueue || _isIndexingSpecificBatch) return;

        _indexSpecificBatchFailed = false;
        _indexSpecificBatchMessage = null;

        var batchIdText = _batchIdToIndex?.Trim();
        if (string.IsNullOrWhiteSpace(batchIdText))
        {
            return;
        }

        _isIndexingSpecificBatch = true;

        try
        {
            await InvokeAsync(StateHasChanged);

            var result = await IndexService.IndexBatchByIdAsync(batchIdText, _disposeCts.Token)
                                           .ConfigureAwait(false);

            if (!result.Succeeded)
            {
                _indexSpecificBatchFailed = true;
                _indexSpecificBatchMessage = result.FailureReason;
                return;
            }

            _indexSpecificBatchMessage = $"Batch '{result.BatchId}' submitted to ingestion queue.";
            Logger.LogInformation("Submitted batch {BatchId} to ingestion queue from UI.", result.BatchId);
        }
        catch (Exception ex)
        {
            _indexSpecificBatchFailed = true;
            _indexSpecificBatchMessage = $"Failed to submit batch '{batchIdText}' to ingestion queue: {ex.Message}";
            Logger.LogError(ex, "Failed to submit batch {BatchId} to ingestion queue.", batchIdText);
        }
        finally
        {
            _isIndexingSpecificBatch = false;
        }
    }

    private async Task OnBusinessUnitChanged(object? value)
    {
        if (value is int businessUnitId)
        {
            _selectedBusinessUnitId = businessUnitId;
        }
        else if (value is string businessUnitIdText && int.TryParse(businessUnitIdText, out var parsedBusinessUnitId))
        {
            _selectedBusinessUnitId = parsedBusinessUnitId;
        }
        else
        {
            _selectedBusinessUnitId = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task IndexBusinessUnitAsync()
    {
        if (_isIndexing || _isDeletingIndexes || _isClearingQueue || _isIndexingSpecificBatch || _isIndexingBusinessUnit || !CanIndexBusinessUnit || _selectedBusinessUnitId is null)
        {
            return;
        }

        var businessUnit = _businessUnits.FirstOrDefault(x => x.Id == _selectedBusinessUnitId.Value);
        if (businessUnit is null)
        {
            _indexBusinessUnitFailed = true;
            _indexBusinessUnitMessage = "The selected business unit could not be found.";
            return;
        }

        _isIndexingBusinessUnit = true;
        _indexBusinessUnitFailed = false;
        _indexBusinessUnitMessage = null;
        _indexBusinessUnitProgressMessage = null;

        try
        {
            await InvokeAsync(StateHasChanged);

            var progress = new Progress<IndexBusinessUnitProgress>(progressUpdate =>
            {
                _indexBusinessUnitProgressMessage = progressUpdate.Message;
                _ = InvokeAsync(StateHasChanged);
            });

            var result = await IndexService.IndexBusinessUnitAsync(businessUnit.Id, businessUnit.Name, progress, _disposeCts.Token)
                                           .ConfigureAwait(false);

            _indexBusinessUnitProgressMessage = null;

            if (!result.Succeeded)
            {
                _indexBusinessUnitFailed = true;
                _indexBusinessUnitMessage = result.IsPartialFailure
                    ? $"Business unit '{businessUnit.Name}' ({businessUnit.Id}) submitted {result.SubmittedCount:N0} of {result.TotalCandidateCount:N0} batch(es) before failure: {result.FailureReason}"
                    : $"Failed to index business unit '{businessUnit.Name}' ({businessUnit.Id}): {result.FailureReason}";
                return;
            }

            _indexBusinessUnitMessage = result.HasNoBatches
                ? $"No unindexed batches were found for business unit '{businessUnit.Name}' ({businessUnit.Id})."
                : $"Submitted {result.SubmittedCount:N0} batch(es) for business unit '{businessUnit.Name}' ({businessUnit.Id}).";
        }
        catch (Exception ex)
        {
            _indexBusinessUnitFailed = true;
            _indexBusinessUnitProgressMessage = null;
            _indexBusinessUnitMessage = $"Failed to index business unit '{businessUnit.Name}' ({businessUnit.Id}): {ex.Message}";
            Logger.LogError(ex, "Failed to index business unit {BusinessUnitName} ({BusinessUnitId}).", businessUnit.Name, businessUnit.Id);
        }
        finally
        {
            await RefreshIndexingStatusAsync().ConfigureAwait(false);
            _isIndexingBusinessUnit = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshIndexingStatusAsync()
    {
        _status = await StatisticsService.GetIndexingStatusAsync()
                                         .ConfigureAwait(false);
    }

    private async Task DeleteIndexesAsync()
    {
        if (_isIndexing || _isDeletingIndexes || _isClearingQueue) return;

        _isDeletingIndexes = true;
        _deleteIndexesFailed = false;
        _deleteIndexesMessage = null;
        _deleteIndexesStage = "Querying indexes";

        try
        {
            await InvokeAsync(StateHasChanged);

            var getResponse = await ElasticsearchClient.Indices.GetAsync("*", CancellationToken.None)
                                                       .ConfigureAwait(false);

            if (!getResponse.IsValidResponse)
            {
                _deleteIndexesFailed = true;
                _deleteIndexesMessage = "Failed to query Elasticsearch for indexes.";
                return;
            }

            var indexNames = getResponse.Indices.Keys.Select(k => k.ToString())
                                        .Where(i => !string.IsNullOrWhiteSpace(i))
                                        .Distinct(StringComparer.Ordinal)
                                        .ToArray();

            if (indexNames.Length == 0)
            {
                _deleteIndexesMessage = "No indexes found.";
                return;
            }

            _deleteIndexesStage = $"Deleting indexes (0 of {indexNames.Length:N0})";
            await InvokeAsync(StateHasChanged);

            var deleted = 0;
            var failed = new List<string>();
            var attempted = 0;

            foreach (var indexName in indexNames)
            {
                attempted++;
                _deleteIndexesStage = $"Deleting indexes ({attempted:N0} of {indexNames.Length:N0})";
                await InvokeAsync(StateHasChanged);

                var deleteResponse = await ElasticsearchClient.Indices.DeleteAsync(indexName, CancellationToken.None)
                                                              .ConfigureAwait(false);

                if (deleteResponse.IsValidResponse)
                {
                    deleted++;
                }
                else
                {
                    failed.Add(indexName);
                }
            }

            if (failed.Count > 0)
            {
                _deleteIndexesFailed = true;
                _deleteIndexesMessage = $"Found {indexNames.Length:N0} index(es). Deleted {deleted:N0}. Failed {failed.Count:N0}: {string.Join(", ", failed)}";
                return;
            }

            _deleteIndexesMessage = $"Found {indexNames.Length:N0} index(es). Deleted {deleted:N0}.";
        }
        catch (Exception ex)
        {
            _deleteIndexesFailed = true;
            _deleteIndexesMessage = $"Failed to delete indexes: {ex.Message}";
        }
        finally
        {
            _isDeletingIndexes = false;
            _deleteIndexesStage = null;
        }
    }

    private async Task ClearQueueAsync()
    {
        if (_isIndexing || _isDeletingIndexes || _isClearingQueue) return;

        _isClearingQueue = true;
        _clearQueueFailed = false;
        _clearQueueMessage = null;
        _clearQueueStage = "Clearing ingestion queue";

        try
        {
            await InvokeAsync(StateHasChanged);

            var result = await IngestionQueueService.ClearAllAsync(_disposeCts.Token)
                                                    .ConfigureAwait(false);

            _clearQueueStage = "Verifying queue is empty";
            await InvokeAsync(StateHasChanged);

            if (!result.Succeeded)
            {
                _clearQueueFailed = true;
                _clearQueueMessage = $"Failed to clear queue: {result.FailureReason}";
                return;
            }

            _clearQueueMessage = result.ItemsRemoved is null
                ? $"Queue cleared and verified empty. Attempts: {result.Attempts:N0}. Duration: {result.Duration:g}"
                : $"Queue cleared and verified empty. Removed {result.ItemsRemoved.Value:N0} item(s). Attempts: {result.Attempts:N0}. Duration: {result.Duration:g}";
        }
        catch (Exception ex)
        {
            _clearQueueFailed = true;
            _clearQueueMessage = $"Failed to clear queue: {ex.Message}";
        }
        finally
        {
            _isClearingQueue = false;
            _clearQueueStage = null;
        }
    }

    private int? Count
    {
        get => _count;
        set => SetCount(value);
    }

    private void SetCount(int? value)
    {
        _count = value;
        ValidateCount();
    }

    private void ValidateCount()
    {
        _canIndex = _count is > 0;
    }

    private async Task IndexAllAsync()
    {
        if (_isIndexing) return;

        _isIndexing = true;
        try
        {
            _ = await IndexService.IndexAllPendingAsync()
                                  .ConfigureAwait(false);
        }
        finally
        {
            _isIndexing = false;
        }
    }

    private async Task IndexNextAsync()
    {
        if (_isIndexing || !_canIndex || _count is null) return;

        _isIndexing = true;
        try
        {
            _ = await IndexService.IndexNextPendingAsync(_count.Value)
                                  .ConfigureAwait(false);
        }
        finally
        {
            _isIndexing = false;
        }
    }

    private async Task ResetAllAsync()
    {
        if (_isIndexing) return;

        _isIndexing = true;
        try
        {
            _ = await IndexService.ResetAllToPendingAsync()
                                  .ConfigureAwait(false);
        }
        finally
        {
            _isIndexing = false;
        }
    }

    public ValueTask DisposeAsync()
    {
        _timer?.Dispose();
        _disposeCts.Cancel();
        _disposeCts.Dispose();
        return ValueTask.CompletedTask;
    }
}