@using QueryServiceHost.Models
@using QueryServiceHost.State
@implements IDisposable

@inject QueryUiState State

<section class="results-panel">
    <header class="results-panel__header">
        <div>
            <h2 class="results-panel__title">Results</h2>
            <p class="results-panel__subtitle">Flat result rows stay visible beside the generated plan workspace.</p>
        </div>

        @if (State.LastResponse is not null)
        {
            <span class="results-panel__summary">@State.LastResponse.Total matches</span>
        }
    </header>

    <div class="results-panel__body">
        @if (State.IsLoading)
        {
            <p class="results-panel__empty-state">Searching...</p>
        }
        else if (!string.IsNullOrWhiteSpace(State.Error))
        {
            <RadzenAlert Variant="Variant.Flat" Severity="AlertSeverity.Error">@State.Error</RadzenAlert>
        }
        else if (State.LastResponse is null)
        {
            <p class="results-panel__empty-state">Run a raw query to populate the result workspace.</p>
        }
        else if (State.LastResponse.Hits.Count == 0)
        {
            <p class="results-panel__empty-state">No results matched the current query.</p>
        }
        else
        {
            <div class="results-panel__list" role="list" aria-label="Query results">
                @foreach (var hit in State.LastResponse.Hits)
                {
                    <button type="button"
                            role="listitem"
                            @key="hit"
                            class="results-panel__row @(IsSelected(hit) ? "results-panel__row--selected" : string.Empty)"
                            @onclick="(() => State.SelectHit(hit))">
                        <span class="results-panel__row-title">@hit.Title</span>
                        <span class="results-panel__row-meta">@GetMetadataText(hit)</span>

                        @if (hit.MatchedFields.Count > 0)
                        {
                            <span class="results-panel__row-matches">Matched: @string.Join(", ", hit.MatchedFields)</span>
                        }
                    </button>
                }
            </div>
        }
    </div>
</section>

@code
{
    protected override void OnInitialized()
    {
        // Subscribe the results panel to shared state changes so completed searches replace the loading message with hits.
        State.Changed += OnStateChanged;
    }

    public void Dispose()
    {
        // Unsubscribe when the component is disposed so the scoped state service does not retain stale callbacks.
        State.Changed -= OnStateChanged;
    }

    private bool IsSelected(Hit hit)
    {
        // Highlight the hit currently selected in the shared state container.
        return State.SelectedHit is not null && ReferenceEquals(State.SelectedHit, hit);
    }

    private static string GetMetadataText(Hit hit)
    {
        // Flatten the most important metadata into a single line so the result list remains easy to scan.
        var segments = new List<string>();

        if (!string.IsNullOrWhiteSpace(hit.Type))
        {
            segments.Add(hit.Type);
        }

        if (!string.IsNullOrWhiteSpace(hit.Region))
        {
            segments.Add(hit.Region);
        }

        return segments.Count == 0 ? "No additional metadata" : string.Join(" | ", segments);
    }

    private void OnStateChanged()
    {
        // Re-render on shared state updates because this component reads injected state rather than receiving parameters.
        InvokeAsync(StateHasChanged);
    }
}
