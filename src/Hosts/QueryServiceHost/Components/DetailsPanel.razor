@using QueryServiceHost.Models
@using QueryServiceHost.State
@implements IDisposable

@inject QueryUiState State

<RadzenCard Variant="Variant.Outlined" Style="height: 100%; min-height: 0; display: flex; flex-direction: column;">
    <RadzenText TextStyle="TextStyle.Subtitle2" Text="Details" />

    <div style="flex: 1; min-height: 0; overflow: auto;">
        @if (State.SelectedHit is null)
        {
            <RadzenText TextStyle="TextStyle.Body2" Text="Select a result to view details." />
        }
        else
        {
            <RadzenStack Gap="0.5rem" Style="padding-top: 0.5rem;">
                <RadzenText TextStyle="TextStyle.H6" Text="@State.SelectedHit.Title" />
                <RadzenText TextStyle="TextStyle.Body2" Text="@($"Type: {State.SelectedHit.Type ?? "(unknown)"}")" />
                <RadzenText TextStyle="TextStyle.Body2" Text="@($"Region: {State.SelectedHit.Region ?? "(unknown)"}")" />

                <RadzenCard Variant="Variant.Outlined" Style="margin-top: 0.5rem;">
                    <RadzenText TextStyle="TextStyle.Subtitle2" Text="Map" />
                    <RadzenText TextStyle="TextStyle.Body2" Text="(map placeholder)" />
                </RadzenCard>

@code
{
    protected override void OnInitialized()
    {
        // Subscribe the details panel to shared state changes so selecting a hit immediately updates the details view.
        State.Changed += OnStateChanged;
    }

    public void Dispose()
    {
        // Unsubscribe when the component is disposed so the scoped state service does not retain stale callbacks.
        State.Changed -= OnStateChanged;
    }

    private void OnStateChanged()
    {
        // Re-render on shared state updates because this component reads injected state rather than receiving parameters.
        InvokeAsync(StateHasChanged);
    }
}

                <RadzenCard Variant="Variant.Outlined">
                    <RadzenText TextStyle="TextStyle.Subtitle2" Text="Attributes" />
                    <RadzenText TextStyle="TextStyle.Body2" Text="(attributes/raw JSON placeholder)" />
                </RadzenCard>
            </RadzenStack>
        }
    </div>
</RadzenCard>
