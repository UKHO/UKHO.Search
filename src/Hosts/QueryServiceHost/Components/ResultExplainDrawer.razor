@using System.Text.Json
@using QueryServiceHost.State
@implements IDisposable
@inject QueryUiState State

@* Hosts the collapsible bottom drawer so selected-result explanation no longer competes with the main diagnostics columns. *@
@{
    var metadataEntries = GetMetadataEntries();
}

<section class="result-explain-drawer" aria-label="Selected result explanation">
    <div class="result-explain-drawer__header">
        <div>
            <h2 class="result-explain-drawer__title">Selected result explanation</h2>
            <p class="result-explain-drawer__subtitle">@GetDrawerSummary()</p>
        </div>

        <RadzenButton Text="@(State.IsResultDrawerOpen ? "Collapse" : "Expand")"
                      ButtonStyle="ButtonStyle.Light"
                      Disabled="@(State.SelectedHit is null)"
                      Click="OnToggleDrawer" />
    </div>

    <div class="result-explain-drawer__content">
        @if (State.SelectedHit is null)
        {
            <p class="result-explain-drawer__placeholder">Select a result row to inspect its lightweight explanation in the bottom drawer.</p>
        }
        else if (!State.IsResultDrawerOpen)
        {
            <p class="result-explain-drawer__placeholder">Expand the drawer to inspect the selected result without crowding the main workspace.</p>
        }
        else
        {
            <div class="result-explain-drawer__details">
                <div>
                    <h3 class="result-explain-drawer__section-title">Explanation summary</h3>
                    <p class="result-explain-drawer__metadata">@GetExplanationSummaryText()</p>
                </div>

                <div>
                    <h3 class="result-explain-drawer__section-title">Key metadata</h3>

                    @if (metadataEntries.Count == 0)
                    {
                        <p class="result-explain-drawer__metadata">No additional metadata is available for the selected result.</p>
                    }
                    else
                    {
                        <ul class="result-explain-drawer__list">
                            @foreach (var metadataEntry in metadataEntries)
                            {
                                <li>@metadataEntry</li>
                            }
                        </ul>
                    }
                </div>

                <div>
                    <h3 class="result-explain-drawer__section-title">Matched fields</h3>
                    <p class="result-explain-drawer__metadata">@GetMatchedFieldsText()</p>
                </div>

                <div>
                    <h3 class="result-explain-drawer__section-title">Raw detail</h3>
                    <pre class="result-explain-drawer__raw">@GetRawJson()</pre>
                </div>
            </div>
        }
    </div>
</section>

@code
{
    private static readonly JsonSerializerOptions RawJsonSerializerOptions = new()
    {
        WriteIndented = true
    };

    protected override void OnInitialized()
    {
        // Subscribe to shared state changes so the drawer follows result selection updates from the flat list.
        State.Changed += OnStateChanged;
    }

    public void Dispose()
    {
        // Unsubscribe when the component is disposed so the scoped state container does not retain stale callbacks.
        State.Changed -= OnStateChanged;
    }

    private string GetDrawerSummary()
    {
        // Keep the drawer summary informative so the footer communicates both selection status and the current execution path.
        if (State.SelectedHit is null)
        {
            return "No result is currently selected.";
        }

        var executionPath = State.LastExecutionUsedEditedPlan ? "edited-plan" : "raw-query";
        return $"Inspecting '{State.SelectedHit.Title}' from the {executionPath} path.";
    }

    private string GetExplanationSummaryText()
    {
        // Build a lightweight explanation summary from the selected hit's matched fields and visible metadata.
        if (State.SelectedHit is null)
        {
            return "No result selected.";
        }

        var segments = new List<string>();

        segments.Add($"Title: {State.SelectedHit.Title}");

        if (!string.IsNullOrWhiteSpace(State.SelectedHit.Type))
        {
            segments.Add($"Type: {State.SelectedHit.Type}");
        }

        if (!string.IsNullOrWhiteSpace(State.SelectedHit.Region))
        {
            segments.Add($"Region: {State.SelectedHit.Region}");
        }

        if (State.SelectedHit.MatchedFields.Count > 0)
        {
            segments.Add($"Matched fields: {string.Join(", ", State.SelectedHit.MatchedFields)}");
        }

        return string.Join(" | ", segments);
    }

    private string GetMatchedFieldsText()
    {
        // Project the matched-field list into readable text for the lightweight explanation shell.
        if (State.SelectedHit is null || State.SelectedHit.MatchedFields.Count == 0)
        {
            return "No matched-field metadata was returned.";
        }

        return string.Join(", ", State.SelectedHit.MatchedFields);
    }

    private string GetRawJson()
    {
        // Format the raw payload when it exists so the drawer can host deeper inspection without crowding the main workspace.
        if (State.SelectedHit?.Raw is not JsonElement raw)
        {
            return "No raw payload was returned for the selected result.";
        }

        return JsonSerializer.Serialize(raw, RawJsonSerializerOptions);
    }

    private IReadOnlyList<string> GetMetadataEntries()
    {
        // Extract a few high-value metadata fields from the raw result payload so the drawer remains useful without full explain support.
        if (State.SelectedHit is null)
        {
            return Array.Empty<string>();
        }

        var entries = new List<string>();

        AddMetadataEntry(entries, "Type", State.SelectedHit.Type);
        AddMetadataEntry(entries, "Region", State.SelectedHit.Region);

        if (State.SelectedHit.Raw is JsonElement raw)
        {
            TryAddJsonArrayMetadata(entries, raw, "category", "Category");
            TryAddJsonArrayMetadata(entries, raw, "format", "Format");
            TryAddJsonArrayMetadata(entries, raw, "authority", "Authority");
            TryAddJsonArrayMetadata(entries, raw, "keywords", "Keywords");
            TryAddJsonArrayMetadata(entries, raw, "majorVersion", "Major version");
            TryAddJsonArrayMetadata(entries, raw, "minorVersion", "Minor version");
        }

        return entries.Distinct(StringComparer.Ordinal).ToArray();
    }

    private void OnToggleDrawer()
    {
        // Route footer collapse and expand requests through shared state so selection and drawer state stay coordinated.
        State.ToggleResultDrawer();
    }

    private static void AddMetadataEntry(ICollection<string> entries, string label, string? value)
    {
        // Append a single metadata entry only when the supplied value carries useful display content.
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        entries.Add($"{label}: {value}");
    }

    private static void TryAddJsonArrayMetadata(ICollection<string> entries, JsonElement raw, string propertyName, string label)
    {
        // Read known canonical document arrays from the raw payload so the drawer can surface key metadata consistently.
        if (!raw.TryGetProperty(propertyName, out var property) || property.ValueKind != JsonValueKind.Array)
        {
            return;
        }

        var values = property.EnumerateArray()
            .Select(static item => item.ValueKind switch
            {
                JsonValueKind.String => item.GetString(),
                JsonValueKind.Number => item.GetRawText(),
                _ => null
            })
            .Where(static value => !string.IsNullOrWhiteSpace(value))
            .Cast<string>()
            .ToArray();

        if (values.Length == 0)
        {
            return;
        }

        entries.Add($"{label}: {string.Join(", ", values)}");
    }

    private void OnStateChanged()
    {
        // Re-render on shared state updates because this component reads injected state rather than receiving parameters.
        InvokeAsync(StateHasChanged);
    }
}
