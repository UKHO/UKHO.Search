@using QueryServiceHost.State
@implements IDisposable
@inject QueryUiState State

@* Renders the generated-plan Monaco workspace that sits beside the flat results list in the centre of the query shell. *@
@{
    var planStatusText = GetPlanStatusText();
}

<section class="query-plan-panel">
    <header class="query-plan-panel__header">
        <div>
            <h2 class="query-plan-panel__title">Generated query plan</h2>
        </div>

        <div class="query-plan-panel__actions">
            <RadzenButton Text="Search"
                          ButtonStyle="ButtonStyle.Primary"
                          Disabled="@IsSearchDisabled()"
                          Click="OnExecuteEditedPlanAsync" />
            <RadzenButton Text="Reset"
                          ButtonStyle="ButtonStyle.Light"
                          Disabled="@IsResetDisabled()"
                          Click="OnResetToGeneratedPlan" />
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(planStatusText))
    {
        <div class="query-plan-panel__status">@planStatusText</div>
    }

    <div class="query-plan-panel__body">
        <JsonEditor Value="@State.EditablePlanText"
                    ValueChanged="@OnEditorValueChanged"
                    IsReadOnly="false"
                    HostStyle="height: 100%; width: 100%;" />
    </div>
</section>

@code
{
    protected override void OnInitialized()
    {
        // Subscribe to shared state changes so the Monaco host refreshes when raw-query execution produces a new generated plan.
        State.Changed += OnStateChanged;
    }

    public void Dispose()
    {
        // Unsubscribe when the component is disposed so the scoped state container does not retain stale callbacks.
        State.Changed -= OnStateChanged;
    }

    private void OnEditorValueChanged(string value)
    {
        // Persist Monaco edits into shared state while leaving the generated-plan baseline untouched.
        State.UpdateEditablePlanText(value);
    }

    private async Task OnExecuteEditedPlanAsync()
    {
        // Route pane-level execution through shared state so validation, logging, and result refresh behavior stay centralized.
        await State.ExecuteEditedPlanAsync(CancellationToken.None);
    }

    private void OnResetToGeneratedPlan()
    {
        // Restore the editor working copy back to the most recent generated raw-query plan.
        State.ResetEditablePlanTextToGeneratedPlan();
    }

    private bool IsSearchDisabled()
    {
        // Disable edited-plan execution only while another run is active or when the editor contains no plan text.
        return State.IsLoading || string.IsNullOrWhiteSpace(State.EditablePlanText);
    }

    private bool IsResetDisabled()
    {
        // Disable reset until a generated baseline exists and the editor has diverged from it.
        return State.IsLoading || !State.CanResetToGeneratedPlan;
    }

    private string GetPlanStatusText()
    {
        // Keep transient and actionable editor state visible without reintroducing the removed descriptive helper copy.
        if (State.IsLoading)
        {
            return State.IsExecutingEditedPlan ? "Executing edited plan..." : "Generating plan from raw query...";
        }

        if (State.HasValidationErrors)
        {
            return "Edited plan validation failed. Review diagnostics and correct the plan.";
        }

        if (State.LastExecutionUsedEditedPlan)
        {
            return "Results currently reflect the edited plan.";
        }

        return State.HasGeneratedPlan ? string.Empty : "Waiting for raw query";
    }

    private void OnStateChanged()
    {
        // Re-render on shared state updates because this component reads injected state rather than receiving parameters.
        InvokeAsync(StateHasChanged);
    }
}
