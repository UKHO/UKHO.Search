{
	"schemaVersion": "1.0",
	"rules": {
		"file-share": [
			{
				"id": "businessunit-adds-exchangeset-keywords",
				"description": "When businessUnit is 'adds', enrich with S63/ENC exchange set keywords and search text.",
				"if": {
					"properties[\"businessUnitName\"]": "adds"
				},
				"then": {
					"facets": {
						"add": [
							{ "name": "businessUnitName", "value": "$path:properties[\"businessUnitName\"]" },
							{ "name": "agency", "value": "$path:properties[\"agency\"]" },
							{ "name": "productCode", "value": "$path:properties[\"productCode\"]" },
							{ "name": "source", "value": "$path:properties[\"source\"]" }
						]
					},
					"keywords": {
						"add": [
							"S63",
							"S-63",
							"ExchangeSet",
							"ENC"
						]
					},
					"searchText": {
						"add": [
							"S63 S-63 Exchange Sets"
						]
					}
				}
			},
