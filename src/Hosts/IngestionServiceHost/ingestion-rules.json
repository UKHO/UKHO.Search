{
	"schemaVersion": "1.0",
	"rules": {
		"file-share": [
			{
				"id": "businessunit-adds-exchangeset-keywords",
				"description": "When businessUnit is 'adds', enrich with S63/ENC exchange set keywords and search text.",
				"if": {
					"properties[\"businessUnitName\"]": "adds"
				},
				"then": {
					"keywords": {
						"add": [
							"S63",
							"S-63",
							"ExchangeSet",
							"ENC"
						]
					},
					"searchText": {
						"add": [
							"S63 S-63 Exchange Sets"
						]
					}
				}
			},
			{
				"id": "businessunit-adds-s57-exchangeset-keywords",
				"description": "When businessUnit is 'adds-s57', enrich with S57/ENC exchange set keywords and search text.",
				"if": {
					"properties[\"businessUnitName\"]": "adds-s57"
				},
				"then": {
					"keywords": {
						"add": [
							"S57",
							"S-57",
							"ExchangeSet",
							"ENC"
						]
					},
					"searchText": {
						"add": [
							"S57 S-57 Exchange Sets"
						]
					}
				}
			}
		]
	}
}