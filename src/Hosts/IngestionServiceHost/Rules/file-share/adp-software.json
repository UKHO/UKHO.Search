{
  "schemaVersion": "1.0",
  "rule": {
    "id": "aenp-data",
    "description": "AENP data releases",
    "if": {
      "all": [
        {
          "path": "properties[\"businessunitname\"]",
          "eq": "aenp"
        }
      ]
    },
    "then": {
      "keywords": {
        "add": [
          "aenp",
          "ukho"
        ]
      },
      "authority": {
        "add": [
          "ukho"
        ]
      },
      "category": {
        "add": [
          "aenp"
        ]
      },
      "series": {
        "add": [
          "aenp"
        ]
      },
      "instance": {
        "add": [
          "$path:properties[\"product id\"]"
        ]
      },
      "majorVersion": {
        "add": [
          "toInt($path:properties[\"year\"])"
        ]
      },
      "minorVersion": {
        "add": [
          "toInt($path:properties[\"edition\"])"
        ]
      },
      "searchText": {
        "add": [
          "aenp data release"
        ]
      }
    }
  }
}
