{
  "schemaVersion": "1.0",
  "rule": {
    "id": "adp-software",
    "description": "ADP software releases",
    "if": {
      "all": [
        {
          "path": "properties[\"businessunitname\"]",
          "eq": "adp"
        },
        {
          "path": "properties[\"adp version\"]",
          "exists": true
        }
      ]
    },
    "then": {
      "keywords": {
        "add": [
          "software",
          "adp",
          "ukho"
        ]
      },
      "authority": {
        "add": [
          "ukho"
        ]
      },
      "category": {
        "add": [
          "software"
        ]
      },
      "series": {
        "add": [
          "adp"
        ]
      },
      "format": {
        "add": [
          "$path:properties[\"media type\"]"
        ]
      },
      "instance": {
        "add": [
          "$path:properties[\"adp version\"]"
        ]
      },
      "majorVersion": {
        "add": [
          "toInt($path:properties[\"adp version\"])"
        ]
      },
      "searchText": {
        "add": [
          "hmnao navpac release"
        ]
      }
    }
  }
}
