@inherits LayoutComponentBase

<RadzenComponents />

@* The Workbench shell now renders explorers, commands, and runtime shell surfaces from contributed models rather than hard-coded navigation markup. *@
<div class="workbench-shell">
    <Grid @key="OutputPanelState.IsVisible" OnResize="HandleOutputPanelResizeAsync">
        <ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </ColumnDefinitions>
        <RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="44" />
            <RowDefinition Height="@WorkingAreaHeight" />
            @if (OutputPanelState.IsVisible)
            {
                <SplitterRowDefinition Height="4" />
                <RowDefinition Height="@OutputPaneHeight" />
            }
            <RowDefinition Height="30" />
        </RowDefinitions>
        <Content>
            @if (IsRegionVisible(WorkbenchShellRegion.MenuBar))
            {
                <GridElement Row="1" Column="1">
                    <header class="workbench-shell__menu-bar" data-region="menu-bar">
                        <div class="workbench-shell__brand">
                            <RadzenIcon Icon="dashboard_customize" />
                            <span>Workbench</span>
                        </div>

                        <nav aria-label="Workbench menu">
                            <ul class="workbench-shell__menu-items">
                                @foreach (var menuContribution in MenuContributions)
                                {
                                    <li>
                                        <button type="button" class="workbench-shell__menu-button" @onclick="() => ExecuteCommandAsync(menuContribution.CommandId)">
                                            @if (!string.IsNullOrWhiteSpace(menuContribution.Icon))
                                            {
                                                <RadzenIcon Icon="@menuContribution.Icon" />
                                            }

                                            <span>@menuContribution.DisplayName</span>
                                        </button>
                                    </li>
                                }
                            </ul>
                        </nav>

                        <div class="workbench-shell__menu-actions">
                            <RadzenAppearanceToggle />
                        </div>
                    </header>
                </GridElement>
            }

            @if (IsRegionVisible(WorkbenchShellRegion.ActiveToolToolbar))
            {
                <GridElement Row="2" Column="1">
                    <section class="workbench-shell__toolbar" data-region="toolbar" aria-label="Workbench toolbar">
                        <div class="workbench-shell__toolbar-home">
                            @if (HomeToolbarContribution is not null)
                            {
                                <button type="button" class="workbench-shell__menu-button workbench-shell__toolbar-home-button" @onclick="() => ExecuteCommandAsync(HomeToolbarContribution.CommandId)">
                                    @if (!string.IsNullOrWhiteSpace(HomeToolbarContribution.Icon))
                                    {
                                        <RadzenIcon Icon="@HomeToolbarContribution.Icon" />
                                    }

                                    <span>@HomeToolbarContribution.DisplayName</span>
                                </button>
                            }
                        </div>

                        <div class="workbench-shell__toolbar-meta">
                            @if (!string.IsNullOrWhiteSpace(ActiveTool?.Badge))
                            {
                                <span class="workbench-shell__badge">@ActiveTool.Badge</span>
                            }

                            @foreach (var toolbarContribution in VisibleToolbarContributions)
                            {
                                <button type="button" class="workbench-shell__menu-button" @onclick="() => ExecuteCommandAsync(toolbarContribution.CommandId)">
                                    @if (!string.IsNullOrWhiteSpace(toolbarContribution.Icon))
                                    {
                                        <RadzenIcon Icon="@toolbarContribution.Icon" />
                                    }

                                    <span>@toolbarContribution.DisplayName</span>
                                </button>
                            }
                        </div>
                    </section>
                </GridElement>
            }

            <GridElement Row="@WorkingAreaRow" Column="1">
                @* The nested grid keeps the working-area splitters isolated so full-width shell chrome does not occupy splitter tracks. *@
                <Grid>
                    <ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" MinWidth="16" />
                        <SplitterColumnDefinition />
                        <ColumnDefinition Width="4*" />
                    </ColumnDefinitions>
                    <RowDefinitions>
                        <RowDefinition Height="*" />
                    </RowDefinitions>
                    <Content>
                        @if (IsRegionVisible(WorkbenchShellRegion.ActivityRail))
                        {
                            <GridElement Row="1" Column="1">
                                <aside class="workbench-shell__activity-rail" data-region="activity-rail" aria-label="Explorer selector">
                                    @foreach (var explorer in Explorers)
                                    {
                                        <button type="button"
                                                class="@GetActivityButtonCss(explorer.Id)"
                                                aria-label="@explorer.DisplayName"
                                                aria-pressed="@IsExplorerActive(explorer.Id)"
                                                @onclick="() => SelectExplorerAsync(explorer.Id)">
                                            <RadzenIcon Icon="@explorer.Icon"
                                                        MouseEnter="element => ShowActivityRailTooltip(element, explorer.DisplayName)"
                                                        MouseLeave="HideTitleTooltip" />
                                        </button>
                                    }
                                </aside>
                            </GridElement>
                        }

                        @if (IsRegionVisible(WorkbenchShellRegion.Explorer))
                        {
                            <GridElement Row="1" Column="2">
                                <aside class="workbench-shell__explorer" data-region="explorer" aria-label="Workbench explorer">
                                    <header class="workbench-shell__explorer-header">
                                        <p>Explorer</p>
                                        <h2>@ActiveExplorerDisplayName</h2>
                                    </header>

                                    @foreach (var explorerSection in ActiveExplorerSections)
                                    {
                                        <section class="workbench-shell__explorer-section" aria-labelledby="@explorerSection.Id">
                                            <h3 id="@explorerSection.Id">@explorerSection.DisplayName</h3>
                                            <ul class="workbench-shell__tool-list">
                                                @foreach (var explorerItem in GetExplorerItems(explorerSection.Id))
                                                {
                                                    <li>
                                                        <button type="button"
                                                                class="@GetExplorerItemButtonCss(explorerItem)"
                                                                data-explorer-item-id="@explorerItem.Id"
                                                                aria-current="@(IsExplorerItemSelected(explorerItem) ? "page" : null)"
                                                                @onclick="args => SelectExplorerItemAsync(explorerItem, args)"
                                                                @ondblclick="args => OpenExplorerItemAsync(explorerItem, args)"
                                                                @onauxclick="IgnoreAuxiliaryClickAsync">
                                                            <RadzenIcon Icon="@explorerItem.Icon" />
                                                            <span class="workbench-shell__tool-copy">
                                                                <strong>@explorerItem.DisplayName</strong>
                                                                @if (!string.IsNullOrWhiteSpace(explorerItem.Description))
                                                                {
                                                                    <span>@explorerItem.Description</span>
                                                                }
                                                            </span>
                                                        </button>
                                                    </li>
                                                }
                                            </ul>
                                        </section>
                                    }
                                </aside>
                            </GridElement>
                        }

                        @if (IsRegionVisible(WorkbenchShellRegion.ToolSurface))
                        {
                            <GridElement Row="1" Column="4">
                                <main class="workbench-shell__tool-surface" data-region="tool-surface">
                                    <section class="workbench-shell__tab-strip"
                                             data-region="tab-strip"
                                             data-tab-strip-spacing="flush-top-bottom-left"
                                             aria-label="Open Workbench tabs">
                                        <div class="workbench-shell__tab-strip-content">
                                            @if (OpenTabs.Count == 0)
                                            {
                                                <span class="workbench-shell__tab-strip-empty">No open tabs</span>
                                            }
                                            else
                                            {
                                                <ul class="workbench-shell__tab-list">
                                                    @foreach (var openTab in VisibleTabs)
                                                    {
                                                        <li class="workbench-shell__tab-list-item" data-tab-id="@openTab.Id">
                                                            <div class="workbench-shell__tab-entry">
                                                                <button type="button"
                                                                        class="@GetTabButtonCss(openTab)"
                                                                        aria-pressed="@IsTabActive(openTab)"
                                                                        aria-haspopup="menu"
                                                                        @onclick="() => ActivateTabAsync(openTab.Id)"
                                                                        @onauxclick="IgnoreAuxiliaryClickAsync"
                                                                        @oncontextmenu="args => OpenTabContextMenuAsync(openTab, args)"
                                                                        @oncontextmenu:preventDefault="true">
                                                                    <RadzenIcon Icon="@openTab.Icon" />
                                                                    @* RadzenText provides a stable component-owned ElementReference so the tooltip service receives a real DOM target on each hover. *@
                                                                    <RadzenText Text="@openTab.Title"
                                                                                TagName="TagName.Span"
                                                                                TextStyle="TextStyle.Body2"
                                                                                class="workbench-shell__tab-title"
                                                                                MouseEnter="element => ShowTitleTooltip(element, openTab.Title)"
                                                                                MouseLeave="HideTitleTooltip" />
                                                                </button>

                                                                @if (IsTabActive(openTab) && openTab.IsClosable)
                                                                {
                                                                    <button type="button"
                                                                            class="workbench-shell__tab-close"
                                                                            aria-label="Close @openTab.Title"
                                                                            @onclick="() => CloseTabAsync(openTab.Id)"
                                                                            @onclick:stopPropagation="true">
                                                                        <RadzenIcon Icon="close" />
                                                                    </button>
                                                                }
                                                            </div>
                                                        </li>
                                                    }
                                                </ul>
                                            }
                                        </div>

                                        @* The overflow dropdown remains visible at all times so users always have a stable path to the full open-tab list. *@
                                        <div class="workbench-shell__tab-overflow"
                                             data-region="tab-strip-overflow"
                                             data-tab-strip-overflow-anchor="right">
                                            <RadzenDropDown TValue="string"
                                                            Data="@OpenTabs"
                                                            TextProperty="Title"
                                                            ValueProperty="Id"
                                                            Value="@(ShellManager.State.ActiveTab?.Id)"
                                                            Placeholder="All tabs"
                                                            Disabled="@(OpenTabs.Count == 0)"
                                                            AllowClear="false"
                                                            Change="SelectOverflowTabAsync"
                                                            ItemRender="ConfigureOverflowItemAttributes"
                                                            class="workbench-shell__tab-overflow-dropdown"
                                                            aria-label="All open Workbench tabs">
                                                <ValueTemplate Context="selectedOverflowTab">
                                                    <span class="workbench-shell__tab-overflow-label">
                                                        <RadzenIcon Icon="more_horiz" />
                                                        <span>All tabs</span>
                                                    </span>
                                                </ValueTemplate>
                                                <Template Context="overflowTabContext">
                                                    @{ var overflowTab = (WorkbenchTab)overflowTabContext; }

                                                    <div class="@GetOverflowEntryCss(overflowTab)"
                                                         data-overflow-tab-id="@overflowTab.Id"
                                                         data-overflow-active="@IsTabActive(overflowTab).ToString().ToLowerInvariant()">
                                                        <RadzenText Text="@overflowTab.Title"
                                                                    TagName="TagName.Span"
                                                                    TextStyle="TextStyle.Body2"
                                                                    class="workbench-shell__overflow-entry-title"
                                                                    MouseEnter="element => ShowTitleTooltip(element, overflowTab.Title)"
                                                                    MouseLeave="HideTitleTooltip" />

                                                        @if (IsTabActive(overflowTab))
                                                        {
                                                            <span class="workbench-shell__overflow-entry-state">Active</span>
                                                        }
                                                    </div>
                                                </Template>
                                            </RadzenDropDown>
                                        </div>
                                    </section>

                                    <div class="workbench-shell__tool-body">
                                        @Body
                                    </div>
                                </main>
                            </GridElement>
                        }
                    </Content>
                </Grid>
            </GridElement>

            @if (OutputPanelState.IsVisible)
            {
                <GridElement Row="@OutputPanelRow" Column="1">
                    <section class="workbench-shell__output-panel" data-region="output-panel" aria-label="Workbench output">
                        <div class="workbench-shell__output-toolbar" role="toolbar" aria-label="Output panel actions">
                            <button type="button"
                                    class="workbench-shell__menu-button"
                                    data-role="output-clear"
                                    @onclick="ClearOutputAsync">
                                <RadzenIcon Icon="delete_sweep" />
                                <span>Clear</span>
                            </button>

                            <button type="button"
                                    class="workbench-shell__menu-button"
                                    data-role="output-auto-scroll"
                                    aria-pressed="@OutputPanelState.IsAutoScrollEnabled"
                                    @onclick="ToggleAutoScrollAsync">
                                <RadzenIcon Icon="vertical_align_bottom" />
                                <span>Auto-scroll</span>
                            </button>

                            <button type="button"
                                    class="workbench-shell__menu-button"
                                    data-role="output-scroll-to-end"
                                    @onclick="ScrollOutputToEndAsync">
                                <RadzenIcon Icon="arrow_downward" />
                                <span>Scroll to end</span>
                            </button>

                            <button type="button"
                                    class="workbench-shell__menu-button"
                                    data-role="output-wrap"
                                    aria-pressed="@OutputPanelState.IsWordWrapEnabled"
                                    @onclick="ToggleWordWrapAsync">
                                <RadzenIcon Icon="wrap_text" />
                                <span>Wrap</span>
                            </button>
                        </div>

                        @* The output stream exposes a stable editor-like surface hook so tests and future styling slices can preserve the read-only text-area contract. *@
                        <div class="@OutputStreamCss"
                             data-output-scroll-mode="@OutputScrollMode"
                             data-output-wrap-mode="@OutputWrapMode"
                             data-output-surface="editor-like"
                             data-output-selection-mode="text-first"
                             data-output-density="dense"
                             data-output-theme-scope="shell-tokens"
                             @ref="_outputStreamElement">
                            @foreach (var outputEntry in OutputEntries)
                            {
                                <WorkbenchOutputRow Entry="outputEntry"
                                                    IsExpanded="@IsOutputEntryExpanded(outputEntry)"
                                                    IsWordWrapEnabled="@OutputPanelState.IsWordWrapEnabled"
                                                    ExpansionToggled="ToggleOutputEntryExpansionAsync" />
                            }
                        </div>
                    </section>
                </GridElement>
            }

            @if (IsRegionVisible(WorkbenchShellRegion.StatusBar))
            {
                <GridElement Row="@StatusBarRow" Column="1">
                    <footer class="workbench-shell__status-bar" data-region="status-bar" role="status" aria-live="polite">
                        <button type="button"
                                class="workbench-shell__menu-button workbench-shell__output-toggle"
                                data-role="output-toggle"
                                data-output-toggle-state="@(OutputPanelState.IsVisible ? "expanded" : "collapsed")"
                                data-output-unseen-level="@(HiddenUnseenLevel?.ToString().ToLowerInvariant())"
                                aria-expanded="@OutputPanelState.IsVisible"
                                @onclick="ToggleOutputPanelAsync">
                            <RadzenIcon Icon="@OutputToggleIcon" />
                            <span>Output</span>

                            @if (HiddenUnseenLevel is not null)
                            {
                                <span class="workbench-shell__output-toggle-indicator"
                                      data-output-unseen-level="@HiddenUnseenLevel.Value.ToString().ToLowerInvariant()">
                                    @HiddenUnseenLevel.Value
                                </span>
                            }
                        </button>

                    </footer>
                </GridElement>
            }
        </Content>
    </Grid>
</div>
