@using UKHO.Workbench.Output

<div class="workbench-shell__output-row"
     data-output-entry-id="@Entry.Id"
     data-output-foldable="@HasExpandableContent.ToString().ToLowerInvariant()"
     data-output-level="@Entry.Level.ToString().ToLowerInvariant()"
     data-output-expanded="@IsExpanded.ToString().ToLowerInvariant()"
     data-output-wrap-mode="@(IsWordWrapEnabled ? "wrapped" : "nowrap")">
    @* The summary line reserves a minimal editor-like gutter for folding and severity cues while keeping the visible text contract unchanged. *@
    <div class="workbench-shell__output-row-summary" data-role="output-entry-summary">
        <div class="workbench-shell__output-gutter">
            @if (HasExpandableContent)
            {
                <button type="button"
                        class="workbench-shell__output-disclosure"
                        data-role="output-entry-toggle"
                        data-output-disclosure-style="gutter"
                        aria-expanded="@IsExpanded"
                        aria-controls="@DetailsRegionId"
                        aria-label="@DisclosureAriaLabel"
                        title="@DisclosureTooltip"
                        @onclick="ToggleExpansionAsync">
                    <span class="workbench-shell__output-disclosure-glyph" aria-hidden="true">@DisclosureGlyph</span>
                </button>
            }
            else
            {
                <span class="workbench-shell__output-disclosure-spacer" aria-hidden="true"></span>
            }
        </div>

        <span class="workbench-shell__output-level-marker"
              data-role="output-gutter-marker"
              data-output-level="@Entry.Level.ToString().ToLowerInvariant()"
              title="@LevelMarkerTooltip"
              aria-hidden="true"></span>
        <div class="workbench-shell__output-main-line" data-role="output-entry-text">
            <span class="workbench-shell__output-timestamp">@FormattedTimestamp</span>
            <span class="workbench-shell__output-source">@Entry.Source</span>
            <span class="workbench-shell__output-summary">@Entry.Summary</span>
        </div>
    </div>

    @if (IsExpanded && HasExpandableContent)
    {
        @* Expanded content renders as indented inline text so the surface still reads like a single editor-like stream rather than nested cards. *@
        <div id="@DetailsRegionId"
             class="workbench-shell__output-row-details"
             data-role="output-entry-details">
            <span class="workbench-shell__output-details-indent" aria-hidden="true"></span>
            <span class="workbench-shell__output-details-marker-spacer" aria-hidden="true"></span>
            <div class="workbench-shell__output-details-lines" data-role="output-entry-detail-text">
                @foreach (var detailLine in DetailLines)
                {
                    <div class="workbench-shell__output-detail-line" data-role="output-detail-line">@detailLine</div>
                }

                @if (!string.IsNullOrWhiteSpace(Entry.EventCode))
                {
                    <div class="workbench-shell__output-detail-line workbench-shell__output-event-code"
                         data-role="output-detail-line"
                         data-output-detail-kind="event-code">
                        Event code: @Entry.EventCode
                    </div>
                }
            </div>
        </div>
    }
</div>
