@page "/"
@rendermode InteractiveServer

<PageTitle>Workbench</PageTitle>

@* The landing page now behaves as the central hosted tool surface instead of rendering the generated Radzen welcome experience. *@
@if (ActiveToolComponentType is null)
{
    <section class="workbench-tool-surface-state" aria-live="polite">
        <h1>No tool selected</h1>
        <p>Select a tool from the explorer to open it in the center work surface.</p>
    </section>
}
else
{
    @* The active tool is rendered through DynamicComponent so the shell stays tool-driven rather than page-driven. *@
    <ErrorBoundary>
        <ChildContent>
            <DynamicComponent @key="ActiveTool!.InstanceId" Type="ActiveToolComponentType" Parameters="ActiveToolParameters" />
        </ChildContent>
        <ErrorContent>
            <section class="workbench-tool-surface-state workbench-tool-surface-state--error" aria-live="assertive">
                <h1>Unable to render the selected tool</h1>
                <p>The selected tool failed while rendering. Refresh the page or inspect the server logs for more detail.</p>
            </section>
        </ErrorContent>
    </ErrorBoundary>
}

