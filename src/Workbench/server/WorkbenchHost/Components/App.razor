@inject ThemeService ThemeService
@implements IDisposable

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    @* Loads the component-scoped stylesheet bundle so page-specific shell styling is applied. *@
    <link rel="stylesheet" href="@Assets["WorkbenchHost.styles.css"]" />
    @* Hosts the active Radzen theme at the application root so runtime theme changes update the entire workbench consistently. *@
    <RadzenTheme Theme="@CurrentTheme" @key="CurrentTheme" />
    @* Enables interactive head updates so runtime Radzen theme changes can replace the active theme asset. *@
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    @* Loads the Radzen runtime script required by Radzen components. *@
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js?v=@(typeof(Radzen.Colors).Assembly.GetName().Version)"></script>
</body>

</html>

@code
{
    /// <summary>
    /// Stores the stock Radzen Material theme name used when the theme service has not selected a value yet.
    /// </summary>
    private const string DefaultThemeName = "material";

    /// <summary>
    /// Gets the active Radzen theme name from the shared theme service.
    /// </summary>
    private string CurrentTheme => string.IsNullOrWhiteSpace(ThemeService.Theme) ? DefaultThemeName : ThemeService.Theme;

    /// <summary>
    /// Subscribes to theme change notifications so the root document head re-renders when the user changes theme.
    /// </summary>
    protected override void OnInitialized()
    {
        // Subscribe once at the app root so any page-level theme selector updates the shared Radzen theme asset.
        ThemeService.ThemeChanged += HandleThemeChanged;
    }

    /// <summary>
    /// Releases the theme change subscription when the root app component is disposed.
    /// </summary>
    public void Dispose()
    {
        // Remove the event subscription to avoid retaining the root component after shutdown.
        ThemeService.ThemeChanged -= HandleThemeChanged;
    }

    /// <summary>
    /// Re-renders the root app component after the shared Radzen theme changes.
    /// </summary>
    private void HandleThemeChanged()
    {
        // Refresh the document head so the active Radzen theme tag follows the user's latest selection.
        InvokeAsync(StateHasChanged);
    }
}
