@page "/"
@rendermode InteractiveServer
@inject ThemeService ThemeService

<PageTitle>Workbench</PageTitle>

<HeadContent>
    @* Hosts the active stock Radzen theme inside the interactive page so changing the selector updates the document head reliably. *@
    <RadzenTheme Theme="@CurrentThemeSelection" @key="CurrentThemeSelection" />
</HeadContent>

@* Establishes the full-viewport shell baseline, including the new menu row above the workbench body. *@
<section class="home-shell @ShellInteractionCssClass"
         @onpointermove="HandleSidebarPointerMoveAsync"
         @onpointerup="StopSidebarResizeAsync"
         @onpointercancel="StopSidebarResizeAsync"
         @onpointerleave="StopSidebarResizeAsync">
    @* Anchors the primary activity bar to the left edge with separate top and bottom icon groups. *@
    <nav class="activity-bar activity-bar-left" aria-label="Workbench activity bar">
        <div class="activity-bar-top-group">
            <RadzenButton class="@GetLeftActivityButtonCssClass(ExplorerPanelId)"
                          Icon="folder_open"
                          title="Explorer"
                          aria-label="Explorer"
                          aria-pressed="@IsLeftPanelActive(ExplorerPanelId)"
                          Click="@(() => ToggleLeftPanelAsync(ExplorerPanelId))" />
            <RadzenButton class="@GetLeftActivityButtonCssClass(SearchPanelId)"
                          Icon="search"
                          title="Search"
                          aria-label="Search"
                          aria-pressed="@IsLeftPanelActive(SearchPanelId)"
                          Click="@(() => ToggleLeftPanelAsync(SearchPanelId))" />
            <RadzenButton class="@GetLeftActivityButtonCssClass(OutlinePanelId)"
                          Icon="timeline"
                          title="Outline"
                          aria-label="Outline"
                          aria-pressed="@IsLeftPanelActive(OutlinePanelId)"
                          Click="@(() => ToggleLeftPanelAsync(OutlinePanelId))" />
        </div>
        <div class="activity-bar-bottom-group">
            <RadzenButton class="activity-button activity-button-utility"
                          Icon="settings"
                          title="Settings"
                          aria-label="Settings"
                          Disabled="true" />
        </div>
    </nav>

    @* Adds the requested application-style menu above the shell body while leaving item behavior placeholder-only. *@
    <header class="home-menu-shell" aria-label="Workbench application menu">
        <RadzenMenu class="home-menu">
            <RadzenMenuItem Text="File">
                <RadzenMenuItem Text="New workspace" />
                <RadzenMenuItem Text="Open recent" />
                <RadzenMenuItem Text="Save snapshot" />
            </RadzenMenuItem>
            <RadzenMenuItem Text="Edit">
                <RadzenMenuItem Text="Undo" />
                <RadzenMenuItem Text="Redo" />
                <RadzenMenuItem Text="Preferences" />
            </RadzenMenuItem>
            <RadzenMenuItem Text="View">
                <RadzenMenuItem Text="Toggle explorer" />
                <RadzenMenuItem Text="Toggle insights" />
                <RadzenMenuItem Text="Reset layout" />
            </RadzenMenuItem>
            <RadzenMenuItem Text="Help">
                <RadzenMenuItem Text="Workbench tour" />
                <RadzenMenuItem Text="Keyboard shortcuts" />
                <RadzenMenuItem Text="About this mock-up" />
            </RadzenMenuItem>
        </RadzenMenu>
    </header>

    @* Keeps the left sidebar mounted so width transitions can animate both opening and closing. *@
    <aside class="@LeftSidebarCssClass" aria-label="Left sidebar" aria-hidden="@(!IsLeftSidebarOpen)" style="@LeftSidebarStyle" @key="_activeLeftPanelId">
        @if (IsLeftSidebarOpen)
        {
            <header class="sidebar-header">
                <span class="sidebar-header-icon" title="@ActiveLeftPanelTooltip" aria-hidden="true">
                    <RadzenIcon Icon="@ActiveLeftPanelIcon" />
                </span>
                <RadzenButton class="sidebar-close"
                              Icon="close"
                              title="Close"
                              aria-label="Close"
                              Click="@CloseLeftPanelAsync"
                              @onclick:stopPropagation="true" />
            </header>
            <div class="sidebar-content">
                @* Uses Radzen buttons for the sidebar tab strip so the shell stays Radzen-native without reintroducing the constrained-layout issues seen with sidebar tabs. *@
                <div class="sidebar-tab-strip" role="tablist" aria-label="Left sidebar sections">
                    <RadzenButton class="@GetSidebarTabButtonCssClass(GetLeftSidebarTabIndex() == 0)"
                                  Text="Explorer"
                                  Click="@(() => HandleLeftSidebarTabChangeAsync(0))" />
                    <RadzenButton class="@GetSidebarTabButtonCssClass(GetLeftSidebarTabIndex() == 1)"
                                  Text="Search"
                                  Click="@(() => HandleLeftSidebarTabChangeAsync(1))" />
                    <RadzenButton class="@GetSidebarTabButtonCssClass(GetLeftSidebarTabIndex() == 2)"
                                  Text="Outline"
                                  Click="@(() => HandleLeftSidebarTabChangeAsync(2))" />
                </div>
                <div class="sidebar-tab-panel" role="tabpanel">
                    @switch (_activeLeftPanelId)
                    {
                        case ExplorerPanelId:
                            <section class="sidebar-placeholder sidebar-placeholder-explorer">
                                <h2>Explorer</h2>
                                <p>Temporary file and workspace placeholders make this panel visibly different from the other mock-ups.</p>
                                @* Uses a Radzen tree here because the explorer placeholder is naturally hierarchical and benefits from Radzen-native affordances. *@
                                <RadzenTree class="sidebar-explorer-tree">
                                    <RadzenTreeItem Text="WorkbenchHost" Icon="folder_open" Expanded="true">
                                        <RadzenTreeItem Text="Components" Icon="folder" />
                                        <RadzenTreeItem Text="Pages" Icon="folder" />
                                    </RadzenTreeItem>
                                    <RadzenTreeItem Text="RulesWorkbench" Icon="folder_open" />
                                    <RadzenTreeItem Text="Search Providers" Icon="folder_open" />
                                </RadzenTree>
                            </section>
                            break;
                        case SearchPanelId:
                            <section class="sidebar-placeholder sidebar-placeholder-search">
                                <h2>Search</h2>
                                <p>This mock panel uses filter chips and a short result list to contrast with the explorer view.</p>
                                <div class="placeholder-chip-row">
                                    <RadzenBadge Text="Charts" />
                                    <RadzenBadge Text="Rules" />
                                    <RadzenBadge Text="Signals" />
                                </div>
                                <ol>
                                    <li>Temporary result A</li>
                                    <li>Temporary result B</li>
                                    <li>Temporary result C</li>
                                </ol>
                            </section>
                            break;
                        case OutlinePanelId:
                            <section class="sidebar-placeholder sidebar-placeholder-outline">
                                <h2>Outline</h2>
                                <p>This mock panel emphasizes structure by showing stacked sections and short descriptive summaries.</p>
                                @* Uses Radzen cards so the outline placeholder demonstrates stock grouped-surface styling instead of custom rows. *@
                                <RadzenCard class="placeholder-outline-item" Variant="Variant.Filled">
                                    <strong>Shell</strong>
                                    <span>Activity bar and panel frame</span>
                                </RadzenCard>
                                <RadzenCard class="placeholder-outline-item" Variant="Variant.Filled">
                                    <strong>Canvas</strong>
                                    <span>Main content and theme switch</span>
                                </RadzenCard>
                                <RadzenCard class="placeholder-outline-item" Variant="Variant.Filled">
                                    <strong>Review</strong>
                                    <span>Desktop-only spacing and resize feel</span>
                                </RadzenCard>
                            </section>
                            break;
                    }
                </div>
            </div>
        }
    </aside>

    @* Places the draggable left separator between the left sidebar and the neutral main canvas. *@
    <div class="@LeftResizeHandleCssClass"
         role="separator"
         aria-label="Resize left sidebar"
         aria-orientation="vertical"
         @onpointerdown="StartLeftSidebarResizeAsync"
         @onpointerdown:stopPropagation="true"></div>

    @* Splits the center workspace into upper and lower panes so the shell now matches the denser workbench layout slice. *@
    <main class="home-main" aria-label="Workbench home shell">
        <RadzenSplitter class="main-workspace-splitter"
                        Orientation="Orientation.Vertical"
                        Style="height: 100%; width: 100%;">
            <RadzenSplitterPane Size="60%" Min="220px" Resizable="true">
                @* Uses a real HTML wrapper inside the splitter pane so the tab host gets explicit, reliable height from standard flex layout. *@
                <div class="workspace-pane-shell workspace-pane-upper"
                     style="display: flex; flex-direction: column; min-width: 0; min-height: 0; height: 100%; overflow: hidden;">
                    <RadzenTabs class="workspace-radzen-tabs"
                                @bind-SelectedIndex="_selectedUpperWorkspaceTabIndex"
                                Style="flex: 1 1 auto; min-width: 0; min-height: 0; width: 100%; height: 100%;">
                        <Tabs>
                            <RadzenTabsItem Text="Forms">
                                @* Groups the sample form controls into a dense but mock-only review surface for light and dark theme comparison. *@
                                <section class="main-pane-content showcase-pane">
                                    <div class="showcase-toolbar">
                                        <div class="showcase-toolbar-copy">
                                            <h2>Radzen form controls</h2>
                                            <p>Review common input, choice, and file-selection controls without leaving the temporary workbench shell.</p>
                                        </div>
                                        <div class="showcase-toolbar-actions">
                                            <RadzenBadge Text="Mock data" />
                                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" class="showcase-theme-picker">
                                                <RadzenLabel Text="Theme" Component="showcaseThemeForms" />
                                                <RadzenDropDown id="showcaseThemeForms"
                                                                Name="ShowcaseThemeForms"
                                                                TValue="string"
                                                                Value="@CurrentThemeSelection"
                                                                Change="@HandleThemeSelectionChangedAsync"
                                                                Data="@_themeOptions"
                                                                TextProperty="Label"
                                                                ValueProperty="Value"
                                                                Style="width: 12rem;" />
                                            </RadzenStack>
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(_showcaseSubmissionMessage))
                                    {
                                        @* Uses Radzen alert feedback so the temporary form confirmation follows the standard Radzen message treatment. *@
                                        <RadzenAlert Variant="Variant.Outlined">
                                            @_showcaseSubmissionMessage
                                        </RadzenAlert>
                                    }

                                    <RadzenTemplateForm TItem="WorkbenchShowcaseFormModel"
                                                        Data="@_showcaseForm"
                                                        Submit="@HandleShowcaseSubmitAsync"
                                                        class="showcase-form-host">
                                        <div class="showcase-form-grid">
                                            <div class="showcase-form-field">
                                                <RadzenFormField Text="Workspace title" Variant="Variant.Outlined">
                                                    <RadzenTextBox Name="WorkspaceTitle"
                                                                   @bind-Value="_showcaseForm.WorkspaceTitle"
                                                                   Style="width: 100%;" />
                                                </RadzenFormField>
                                                <RadzenRequiredValidator Component="WorkspaceTitle" Text="Enter a title for this visual review sample." />
                                            </div>

                                            <div class="showcase-form-field showcase-form-field-wide">
                                                <RadzenFormField Text="Review notes" Variant="Variant.Outlined">
                                                    <RadzenTextArea Name="ReviewNotes"
                                                                    @bind-Value="_showcaseForm.ReviewNotes"
                                                                    Style="width: 100%; min-height: 8rem;" />
                                                </RadzenFormField>
                                                <p class="showcase-helper-text">Helper copy stays intentionally light so reviewers can focus on spacing, borders, and typography.</p>
                                            </div>

                                            <div class="showcase-form-field">
                                                <RadzenFormField Text="Result limit" Variant="Variant.Outlined">
                                                    <RadzenNumeric Name="ResultLimit"
                                                                   TValue="int"
                                                                   Min="10"
                                                                   Max="500"
                                                                   Step="10"
                                                                   @bind-Value="_showcaseForm.ResultLimit"
                                                                   Style="width: 100%;" />
                                                </RadzenFormField>
                                            </div>

                                            <div class="showcase-form-field">
                                                <RadzenFormField Text="Review date" Variant="Variant.Outlined">
                                                    <RadzenDatePicker Name="ReviewDate"
                                                                      TValue="DateTime?"
                                                                      DateFormat="dd MMM yyyy"
                                                                      @bind-Value="_showcaseForm.ReviewDate"
                                                                      Style="width: 100%;" />
                                                </RadzenFormField>
                                            </div>

                                            <div class="showcase-form-field">
                                                <RadzenFormField Text="Dataset" Variant="Variant.Outlined">
                                                    <RadzenDropDown Name="Dataset"
                                                                    TValue="string"
                                                                    Data="@_datasetOptions"
                                                                    TextProperty="Label"
                                                                    ValueProperty="Value"
                                                                    @bind-Value="_showcaseForm.Dataset"
                                                                    Style="width: 100%;" />
                                                </RadzenFormField>
                                                <RadzenRequiredValidator Component="Dataset" Text="Select a dataset to complete the visual review sample." />
                                            </div>

                                            <div class="showcase-form-field showcase-form-field-wide">
                                                <RadzenFormField Text="Reference file" Variant="Variant.Outlined">
                                                    <RadzenFileInput Name="ReferenceFile"
                                                                     TValue="string"
                                                                     Accept=".csv,.json,.txt"
                                                                     ChooseText="Choose sample file"
                                                                     @bind-Value="_showcaseForm.ReferenceFileContent"
                                                                     Style="width: 100%;" />
                                                </RadzenFormField>
                                                <p class="showcase-helper-text">The file chooser is visual-only and keeps all content local to the current browser session.</p>
                                            </div>
                                        </div>

                                        <div class="showcase-choice-grid">
                                            <RadzenCard class="showcase-choice-card" Variant="Variant.Filled" aria-label="Pinned overview sample">
                                                <div>
                                                    <h3>Pin overview tab</h3>
                                                    <p>Sample checkbox styling for a persistent workspace preference.</p>
                                                </div>
                                                <RadzenCheckBox Name="PinOverview"
                                                                TValue="bool"
                                                                TriState="false"
                                                                @bind-Value="_showcaseForm.PinOverview" />
                                            </RadzenCard>

                                            <RadzenCard class="showcase-choice-card" Variant="Variant.Filled" aria-label="Automatic refresh sample">
                                                <div>
                                                    <h3>Automatic refresh</h3>
                                                    <p>Sample switch styling for a low-friction toggle state.</p>
                                                </div>
                                                <RadzenSwitch Name="AutoRefresh"
                                                              TValue="bool"
                                                              @bind-Value="_showcaseForm.AutoRefresh" />
                                            </RadzenCard>

                                            <RadzenCard class="showcase-choice-card showcase-choice-card-wide" Variant="Variant.Filled" aria-label="Density selection sample">
                                                <div>
                                                    <h3>Layout density</h3>
                                                    <p>Static radio options help reviewers compare grouped choice treatments.</p>
                                                </div>
                                                <RadzenRadioButtonList Name="LayoutDensity"
                                                                       TValue="string"
                                                                       Data="@_densityOptions"
                                                                       TextProperty="Label"
                                                                       ValueProperty="Value"
                                                                       @bind-Value="_showcaseForm.LayoutDensity" />
                                            </RadzenCard>
                                        </div>

                                        <div class="showcase-form-actions">
                                            <RadzenButton Text="Preview styles"
                                                          Icon="visibility"
                                                          ButtonType="ButtonType.Submit" />
                                        </div>
                                    </RadzenTemplateForm>
                                </section>
                            </RadzenTabsItem>
                            <RadzenTabsItem Text="Tree">
                                @* Uses a static hierarchy so reviewers can compare Radzen tree spacing, selection affordances, and icon rhythm. *@
                                <section class="main-pane-content showcase-pane showcase-data-pane">
                                    <div class="showcase-toolbar">
                                        <div class="showcase-toolbar-copy">
                                            <h2>Sample tree</h2>
                                            <p>The hierarchy remains entirely in-memory and intentionally generic while showcasing expansion, icons, and nested indentation.</p>
                                        </div>
                                        <div class="showcase-toolbar-actions">
                                            <RadzenBadge Text="@TreeRootCountText" />
                                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" class="showcase-theme-picker">
                                                <RadzenLabel Text="Theme" Component="showcaseThemeTree" />
                                                <RadzenDropDown id="showcaseThemeTree"
                                                                Name="ShowcaseThemeTree"
                                                                TValue="string"
                                                                Value="@CurrentThemeSelection"
                                                                Change="@HandleThemeSelectionChangedAsync"
                                                                Data="@_themeOptions"
                                                                TextProperty="Label"
                                                                ValueProperty="Value"
                                                                Style="width: 12rem;" />
                                            </RadzenStack>
                                        </div>
                                    </div>

                                    <div class="showcase-data-grid-layout">
                                        <RadzenCard class="showcase-panel-card" Variant="Variant.Filled">
                                            <h3>Hierarchy preview</h3>
                                            <p class="showcase-helper-text">Checkboxes are enabled only to expose the full control styling surface for theme review.</p>
                                            <RadzenTree AllowCheckBoxes="true" class="showcase-tree">
                                                @foreach (var rootNode in _treeNodes)
                                                {
                                                    <RadzenTreeItem Text="@rootNode.Text" Icon="@rootNode.Icon" Expanded="@rootNode.IsExpanded">
                                                        @foreach (var childNode in rootNode.Children)
                                                        {
                                                            <RadzenTreeItem Text="@childNode.Text" Icon="@childNode.Icon" Expanded="@childNode.IsExpanded">
                                                                @foreach (var grandchildNode in childNode.Children)
                                                                {
                                                                    <RadzenTreeItem Text="@grandchildNode.Text" Icon="@grandchildNode.Icon" Expanded="@grandchildNode.IsExpanded" />
                                                                }
                                                            </RadzenTreeItem>
                                                        }
                                                    </RadzenTreeItem>
                                                }
                                            </RadzenTree>
                                        </RadzenCard>

                                        <RadzenCard class="showcase-panel-card" Variant="Variant.Filled">
                                            <h3>Review prompts</h3>
                                            <ul class="showcase-note-list">
                                                <li>Confirm the tree icons and checkbox states remain readable in both shell themes.</li>
                                                <li>Compare collapsed versus expanded indentation to judge density in the upper workspace.</li>
                                                <li>Use the sidebars and splitter while this tab is active to verify the tree remains visually stable.</li>
                                            </ul>
                                        </RadzenCard>
                                    </div>
                                </section>
                            </RadzenTabsItem>
                            <RadzenTabsItem Text="Grid">
                                @* Uses fixed row data so the data grid can demonstrate headers, paging, templates, and date rendering without backend calls. *@
                                <section class="main-pane-content showcase-pane showcase-data-pane">
                                    <div class="showcase-toolbar">
                                        <div class="showcase-toolbar-copy">
                                            <h2>Sample data grid</h2>
                                            <p>The grid keeps sorting and paging lightweight so reviewers can focus on Radzen styling rather than workflow behavior.</p>
                                        </div>
                                        <div class="showcase-toolbar-actions">
                                            <RadzenBadge Text="@GridRowCountText" />
                                            <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" class="showcase-theme-picker">
                                                <RadzenLabel Text="Theme" Component="showcaseThemeGrid" />
                                                <RadzenDropDown id="showcaseThemeGrid"
                                                                Name="ShowcaseThemeGrid"
                                                                TValue="string"
                                                                Value="@CurrentThemeSelection"
                                                                Change="@HandleThemeSelectionChangedAsync"
                                                                Data="@_themeOptions"
                                                                TextProperty="Label"
                                                                ValueProperty="Value"
                                                                Style="width: 12rem;" />
                                            </RadzenStack>
                                        </div>
                                    </div>

                                    <RadzenCard class="showcase-panel-card showcase-grid-card" Variant="Variant.Filled">
                                        <RadzenDataGrid Data="@_gridRows"
                                                        TItem="WorkbenchShowcaseGridRow"
                                                        AllowPaging="true"
                                                        PageSize="5"
                                                        AllowSorting="true"
                                                        class="showcase-grid">
                                            <Columns>
                                                <RadzenDataGridColumn TItem="WorkbenchShowcaseGridRow" Property="Title" Title="Title" />
                                                <RadzenDataGridColumn TItem="WorkbenchShowcaseGridRow" Property="Category" Title="Category" />
                                                <RadzenDataGridColumn TItem="WorkbenchShowcaseGridRow" Property="Owner" Title="Owner" />
                                                <RadzenDataGridColumn TItem="WorkbenchShowcaseGridRow" Title="Status">
                                                    <Template Context="row">
                                                        <RadzenBadge Text="@row.Status" />
                                                    </Template>
                                                </RadzenDataGridColumn>
                                                <RadzenDataGridColumn TItem="WorkbenchShowcaseGridRow" Property="Confidence" Title="Confidence %" />
                                                <RadzenDataGridColumn TItem="WorkbenchShowcaseGridRow"
                                                                      Property="LastReviewedOn"
                                                                      Title="Reviewed"
                                                                      FormatString="{0:dd MMM yyyy}" />
                                            </Columns>
                                        </RadzenDataGrid>
                                    </RadzenCard>
                                </section>
                            </RadzenTabsItem>
                        </Tabs>
                    </RadzenTabs>
                </div>
            </RadzenSplitterPane>
            <RadzenSplitterPane Size="40%" Min="180px">
                @* Mirrors the upper-pane wrapper so the lower tab host receives the same explicit height contract. *@
                <div class="workspace-pane-shell workspace-pane-lower"
                     style="display: flex; flex-direction: column; min-width: 0; min-height: 0; height: 100%; overflow: hidden;">
                    <RadzenTabs class="workspace-radzen-tabs"
                                @bind-SelectedIndex="_selectedLowerWorkspaceTabIndex"
                                Style="flex: 1 1 auto; min-width: 0; min-height: 0; width: 100%; height: 100%;">
                        <Tabs>
                            <RadzenTabsItem Text="Console">
                                <section class="main-pane-content main-pane-content-secondary lower-pane-content">
                                    <h2>Console</h2>
                                    <p>This lower placeholder pane can host future execution output once the mock-up grows beyond shell review.</p>
                                    <p>For now it simply demonstrates the requested second workbench region beneath the upper tabs.</p>
                                </section>
                            </RadzenTabsItem>
                            <RadzenTabsItem Text="Problems">
                                <section class="main-pane-content main-pane-content-secondary lower-pane-content">
                                    <h2>Problems</h2>
                                    <p>The lower pane remains intentionally visual-first, with alternate placeholder copy to prove tab switching and layout balance.</p>
                                    <p>No diagnostics, persistence, or backend integration are wired in this refinement slice.</p>
                                </section>
                            </RadzenTabsItem>
                            <RadzenTabsItem Text="Output">
                                <section class="main-pane-content main-pane-content-secondary lower-pane-content">
                                    <h2>Output</h2>
                                    <p>This tab reserves space for future review traces while keeping the current implementation entirely mock-up oriented.</p>
                                    <p>The splitter above stays resizable so reviewers can judge the balance between the upper and lower panes.</p>
                                </section>
                            </RadzenTabsItem>
                        </Tabs>
                    </RadzenTabs>
                </div>
            </RadzenSplitterPane>
        </RadzenSplitter>
    </main>

    @* Places the draggable right separator between the main canvas and the mirrored right sidebar. *@
    <div class="@RightResizeHandleCssClass"
         role="separator"
         aria-label="Resize right sidebar"
         aria-orientation="vertical"
         @onpointerdown="StartRightSidebarResizeAsync"
         @onpointerdown:stopPropagation="true"></div>

    @* Keeps the right sidebar mounted so width transitions can animate while the activity bar remains edge anchored. *@
    <aside class="@RightSidebarCssClass" aria-label="Right sidebar" aria-hidden="@(!IsRightSidebarOpen)" style="@RightSidebarStyle" @key="_activeRightPanelId">
        @if (IsRightSidebarOpen)
        {
            <header class="sidebar-header">
                <span class="sidebar-header-icon" title="@ActiveRightPanelTooltip" aria-hidden="true">
                    <RadzenIcon Icon="@ActiveRightPanelIcon" />
                </span>
                <RadzenButton class="sidebar-close"
                              Icon="close"
                              title="Close"
                              aria-label="Close"
                              Click="@CloseRightPanelAsync"
                              @onclick:stopPropagation="true" />
            </header>
            <div class="sidebar-content">
                @* Mirrors the left sidebar implementation so both sidebars use a stable Radzen-native tab strip. *@
                <div class="sidebar-tab-strip" role="tablist" aria-label="Right sidebar sections">
                    <RadzenButton class="@GetSidebarTabButtonCssClass(GetRightSidebarTabIndex() == 0)"
                                  Text="Insights"
                                  Click="@(() => HandleRightSidebarTabChangeAsync(0))" />
                    <RadzenButton class="@GetSidebarTabButtonCssClass(GetRightSidebarTabIndex() == 1)"
                                  Text="Activity"
                                  Click="@(() => HandleRightSidebarTabChangeAsync(1))" />
                </div>
                <div class="sidebar-tab-panel" role="tabpanel">
                    @switch (_activeRightPanelId)
                    {
                        case InsightsPanelId:
                            <section class="sidebar-placeholder sidebar-placeholder-insights">
                                <h2>Insights</h2>
                                <p>This placeholder leans on compact status metrics so it reads differently from the left-side panels.</p>
                                <div class="placeholder-metric-grid">
                                    <RadzenCard class="placeholder-metric-item" Variant="Variant.Filled">
                                        <strong>14</strong>
                                        <span>Open notes</span>
                                    </RadzenCard>
                                    <RadzenCard class="placeholder-metric-item" Variant="Variant.Filled">
                                        <strong>3</strong>
                                        <span>Pending checks</span>
                                    </RadzenCard>
                                    <RadzenCard class="placeholder-metric-item" Variant="Variant.Filled">
                                        <strong>92%</strong>
                                        <span>Shell fit</span>
                                    </RadzenCard>
                                </div>
                            </section>
                            break;
                        case ActivityPanelId:
                            <section class="sidebar-placeholder sidebar-placeholder-activity">
                                <h2>Activity</h2>
                                <p>This placeholder uses a timeline layout so the mirrored sidebar content is visibly distinct.</p>
                                <div class="placeholder-timeline">
                                    <RadzenCard class="placeholder-timeline-item" Variant="Variant.Filled">
                                        <strong>09:10</strong>
                                        <span>Mock review opened</span>
                                    </RadzenCard>
                                    <RadzenCard class="placeholder-timeline-item" Variant="Variant.Filled">
                                        <strong>09:24</strong>
                                        <span>Right panel resized</span>
                                    </RadzenCard>
                                    <RadzenCard class="placeholder-timeline-item" Variant="Variant.Filled">
                                        <strong>09:41</strong>
                                        <span>Theme toggled for contrast check</span>
                                    </RadzenCard>
                                </div>
                            </section>
                            break;
                    }
                </div>
            </div>
        }
    </aside>

    @* Anchors the mirrored secondary activity bar to the outer right edge with two top-aligned icon buttons. *@
    <nav class="activity-bar activity-bar-right" aria-label="Workbench secondary activity bar">
        <div class="activity-bar-top-group">
            <RadzenButton class="@GetRightActivityButtonCssClass(InsightsPanelId)"
                          Icon="monitoring"
                          title="Insights"
                          aria-label="Insights"
                          aria-pressed="@IsRightPanelActive(InsightsPanelId)"
                          Click="@(() => ToggleRightPanelAsync(InsightsPanelId))" />
            <RadzenButton class="@GetRightActivityButtonCssClass(ActivityPanelId)"
                          Icon="notifications"
                          title="Activity"
                          aria-label="Activity"
                          aria-pressed="@IsRightPanelActive(ActivityPanelId)"
