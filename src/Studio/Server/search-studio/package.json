{
  "name": "search-studio",
  "description": "Native Theia extension for UKHO Search Studio.",
  "keywords": [
    "theia-extension"
  ],
  "version": "0.0.0",
  "files": [
    "lib",
    "src"
  ],
  "dependencies": {
