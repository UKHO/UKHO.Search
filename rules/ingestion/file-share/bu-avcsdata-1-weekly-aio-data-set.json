{
    "schemaVersion": "1.0",
    "rule": {
        "id": "bu-avcsdata-1-weekly-aio-data-set",
        "context": "avcsdata",
        "title": "AVCSData weekly AIO data set $path:properties[\"year / week\"]",
        "description": "AVCSData weekly AIO data set.",
        "enabled": true,
        "if": {
            "all": [
                {
                    "path": "properties[\"businessunitname\"]",
                    "eq": "avcsdata"
                },
                {
                    "path": "properties[\"product type\"]",
                    "eq": "aio"
                },
                {
                    "path": "properties[\"exchange set type\"]",
                    "exists": true
                }
            ]
        },
        "then": {
            "keywords": {
                "add": [
                    "aio",
                    "weekly",
                    "dataset"
                ]
            },
            "authority": {
                "add": [
                    "ukho"
                ]
            },
            "majorVersion": {
                "add": [
                    "toInt($path:properties[\"year\"])"
                ]
            },
            "minorVersion": {
                "add": [
                    "toInt($path:properties[\"week number\"])"
                ]
            },
            "category": {
                "add": [
                    "exchange set"
                ]
            },
            "series": {
                "add": [
                    "avcs"
                ]
            },
            "instance": {
                "add": [
                    "$path:properties[\"year / week\"]"
                ]
            },
            "searchText": {
                "add": [
                    "weekly aio data set for $path:properties[\"year / week\"]"
                ]
            }
        }
    }
}
