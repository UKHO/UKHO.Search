{
    "schemaVersion": "1.0",
    "rule": {
        "id": "bu-adds-s100-3-base-exchange-set-product-code",
        "context": "adds-s100",
        "title": "ADDS-S100 $path:properties[\"exchange set type\"] base exchange set",
        "description": "ADDS-S100 base exchange set using product code.",
        "enabled": true,
        "if": {
            "all": [
                {
                    "path": "properties[\"businessunitname\"]",
                    "eq": "adds-s100"
                },
                {
                    "path": "properties[\"exchange set type\"]",
                    "exists": true
                },
                {
                    "path": "properties[\"product code\"]",
                    "exists": true
                },
                {
                    "path": "properties[\"product type\"]",
                    "exists": false
                }
            ]
        },
        "then": {
            "keywords": {
                "add": [
                    "s100",
                    "base",
                    "exchange set",
                    "daily"
                ]
            },
            "authority": {
                "add": [
                    "ukho"
                ]
            },
            "format": {
                "add": [
                    "$path:properties[\"media type\"]"
                ]
            },
            "category": {
                "add": [
                    "exchange set"
                ]
            },
            "series": {
                "add": [
                    "s-100",
                    "s100"
                ]
            },
            "instance": {
                "add": [
                    "$path:properties[\"exchange set type\"]"
                ]
            },
            "searchText": {
                "add": [
                    "daily s100 base exchange set in $path:properties[\"media type\"] format"
                ]
            }
        }
    }
}
