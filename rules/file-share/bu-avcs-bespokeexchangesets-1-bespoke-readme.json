{
    "schemaVersion": "1.0",
    "rule": {
        "id": "bu-avcs-bespokeexchangesets-1-bespoke-readme",
        "context": "avcs-bespokeexchangesets",
        "description": "AVCS bespoke exchange set readme.",
        "enabled": true,
        "if": {
            "all": [
                {
                    "path": "properties[\"businessunitname\"]",
                    "eq": "avcs-bespokeexchangesets"
                },
                {
                    "path": "properties[\"content\"]",
                    "eq": "bespoke readme"
                }
            ]
        },
        "then": {
            "keywords": {
                "add": [
                    "bespoke",
                    "readme",
                    "avcs"
                ]
            },
            "authority": {
                "add": [
                    "ukho"
                ]
            },
            "format": {
                "add": [
                    "text"
                ]
            },
            "category": {
                "add": [
                    "support"
                ]
            },
            "series": {
                "add": [
                    "avcs"
                ]
            },
            "instance": {
                "add": [
                    "$path:properties[\"audience\"]"
                ]
            },
            "searchText": {
                "add": [
                    "bespoke avcs readme for $path:properties[\"audience\"]"
                ]
            }
        }
    }
}
