{
    "schemaVersion": "1.0",
    "rule": {
        "id": "bu-avcsdata-5-annual-catalogue",
        "description": "AVCSData annual catalogue.",
        "enabled": true,
        "if": {
            "all": [
                {
                    "path": "properties[\"businessunitname\"]",
                    "eq": "avcsdata"
                },
                {
                    "path": "properties[\"content\"]",
                    "eq": "catalogue"
                },
                {
                    "path": "properties[\"week number\"]",
                    "exists": false
                }
            ]
        },
        "then": {
            "keywords": {
                "add": [
                    "avcs",
                    "catalogue"
                ]
            },
            "authority": {
                "add": [
                    "ukho"
                ]
            },
            "format": {
                "add": [
                    "catalogue"
                ]
            },
            "majorVersion": {
                "add": [
                    "toInt($path:properties[\"year\"])"
                ]
            },
            "category": {
                "add": [
                    "catalogue"
                ]
            },
            "series": {
                "add": [
                    "avcs"
                ]
            },
            "instance": {
                "add": [
                    "$path:properties[\"year\"]"
                ]
            },
            "searchText": {
                "add": [
                    "avcs catalogue for $path:properties[\"year\"]"
                ]
            }
        }
    }
}
