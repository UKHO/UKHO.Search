{
  "schemaVersion": "1.0",
  "rule": {
    "id": "arcs-data",
    "description": "ARCS data releases",
    "if": {
      "all": [
        {
          "path": "properties[\"businessunitname\"]",
          "eq": "arcs"
        }
      ]
    },
    "then": {
      "keywords": {
        "add": [
          "arcs",
          "zip"
        ]
      },
      "authority": {
        "add": [
          "ukho"
        ]
      },
      "category": {
        "add": [
          "arcs"
        ]
      },
      "series": {
        "add": [
          "arcs"
        ]
      },
      "format": {
        "add": [
          "$path:properties[\"media type\"]"
        ]
      },
      "instance": {
        "add": [
          "$path:properties[\"year / week\"]",
          "$path:properties[\"disc\"]"
        ]
      },
      "majorVersion": {
        "add": [
          "toInt($path:properties[\"year\"])"
        ]
      },
      "minorVersion": {
        "add": [
          "toInt($path:properties[\"week number\"])"
        ]
      },
      "searchText": {
        "add": [
          "hmnao navpac release"
        ]
      }
    }
  }
}
