{
    "schemaVersion": "1.0",
    "rule": {
        "id": "bu-printtoorder-9-dimensions-basic",
        "context": "printtoorder",
        "description": "PrintToOrder paper chart with dimensions.",
        "enabled": true,
        "if": {
            "all": [
                {
                    "path": "properties[\"businessunitname\"]",
                    "eq": "printtoorder"
                },
                {
                    "path": "properties[\"chart version id\"]",
                    "exists": false
                },
                {
                    "path": "properties[\"edition date\"]",
                    "exists": false
                },
                {
                    "path": "properties[\"paper depth\"]",
                    "exists": true
                }
            ]
        },
        "then": {
            "keywords": {
                "add": [
                    "paper",
                    "chart"
                ]
            },
            "authority": {
                "add": [
                    "ukho"
                ]
            },
            "format": {
                "add": [
                    "paper"
                ]
            },
            "majorVersion": {
                "add": [
                    "toInt($path:properties[\"edition number\"])"
                ]
            },
            "category": {
                "add": [
                    "paper chart"
                ]
            },
            "instance": {
                "add": [
                    "$path:properties[\"chart number\"]"
                ]
            },
            "searchText": {
                "add": [
                    "paper chart $path:properties[\"chart number\"] $path:properties[\"chart title\"] edition $path:properties[\"edition number\"]"
                ]
            }
        }
    }
}
