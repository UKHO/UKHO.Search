{
    "schemaVersion": "1.0",
    "rule": {
        "id": "bu-printtoorder-1-chart-version-nm-plan",
        "context": "printtoorder",
        "title": "Paper chart $path:properties[\"chart number\"] $path:properties[\"chart title\"]",
        "description": "PrintToOrder paper chart with chart version, NM, and plan.",
        "enabled": true,
        "if": {
            "all": [
                {
                    "path": "properties[\"businessunitname\"]",
                    "eq": "printtoorder"
                },
                {
                    "path": "properties[\"chart version id\"]",
                    "exists": true
                },
                {
                    "path": "properties[\"nm number\"]",
                    "exists": true
                },
                {
                    "path": "properties[\"plan type\"]",
                    "exists": true
                },
                {
                    "path": "properties[\"int number\"]",
                    "exists": false
                }
            ]
        },
        "then": {
            "keywords": {
                "add": [
                    "paper",
                    "chart",
                    "print",
                    "nm"
                ]
            },
            "authority": {
                "add": [
                    "ukho"
                ]
            },
            "format": {
                "add": [
                    "paper"
                ]
            },
            "majorVersion": {
                "add": [
                    "toInt($path:properties[\"edition number\"])"
                ]
            },
            "category": {
                "add": [
                    "paper chart"
                ]
            },
            "instance": {
                "add": [
                    "$path:properties[\"chart number\"]"
                ]
            },
            "searchText": {
                "add": [
                    "paper chart $path:properties[\"chart number\"] $path:properties[\"chart title\"] edition $path:properties[\"edition number\"]"
                ]
            }
        }
    }
}
