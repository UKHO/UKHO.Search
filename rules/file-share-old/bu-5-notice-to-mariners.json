{
  "schemaVersion": "1.0",
  "rule": {
    "id": "notice-to-mariners",
    "description": "Notice to Mariners",
    "if": {
      "all": [
        {
          "path": "properties[\"businessunitname\"]",
          "eq": "maritimesafetyinformation"
        }
      ]
    },
    "then": {
      "keywords": {
        "add": [
          "ntm",
          "safety",
          "maritime",
          "notice",
          "mariners",
          "$path:properties[\"frequency\"]"
        ]
      },
      "authority": {
        "add": [
          "ukho"
        ]
      },
      "category": {
        "add": [
          "notice to mariners"
        ]
      },
      "series": {
        "add": [
          "weekly"
        ]
      },
      "instance": {
        "add": [
          "$path:properties[\"data date\"]"
        ]
      },
      "majorVersion": {
        "add": [
          "toInt($path:properties[\"year\"])"
        ]
      },
      "minorVersion": {
        "add": [
          "toInt($path:properties[\"week number\"])"
        ]
      },
      "searchText": {
        "add": [
          "maritime safety notice to mariners"
        ]
      }
    }
  }
}
